                    svg.innerHTML += `<defs><linearGradient id="g-f-2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#dcfce7"/><stop offset="100%" stop-color="#bbf7d0"/></linearGradient></defs><rect width="100%" height="100%" fill="url(#g-f-2)" /><path d="M0 250 Q 150 200 300 280 T 500 250 L 500 400 L 0 400 Z" fill="#86efac" opacity="0.5"/><g opacity="0.8" class="float-obj-slow"><rect x="60" y="270" width="16" height="50" fill="#78350f" rx="2" /><circle cx="68" cy="240" r="35" fill="#22c55e" /><circle cx="50" cy="250" r="25" fill="#16a34a" /><circle cx="86" cy="250" r="25" fill="#16a34a" /></g><circle cx="400" cy="100" r="4" fill="#fbbf24" opacity="0.6" class="float-obj"/><circle cx="430" cy="130" r="3" fill="#fbbf24" opacity="0.5" class="float-obj" style="animation-delay: 1s;"/>`;
                },
                stages: [
                    { title: "שלב 1: מחנה הפיות", desc: "נכנסנו ליער הקסום. הפיות מבקשות שנעזור להן לבנות שביל מגן מסביב למחנה." },
                    { title: "שלב 2: מזח הנהר", desc: "תודה שעזרתם לפיות! כהוקרת תודה הן הראו לנו נהר, בואו נחשב את מידות המזח לחצות אותו." },
                    { title: "שלב 3: עץ החיים", desc: "חצינו את הנהר והגענו ללב היער, עץ החיים. הבסיס שלו דורש חישוב מורכב." },
                    { title: "שלב 4: המערה הסודית", desc: "מתחת לעץ מסתתרת מערה קסומה. פתרו את חידת מידות הפתח כדי להיכנס." },
                    { title: "שלב 5: מסיבת היער", desc: "מצאנו את הקריסטל במערה! עכשיו בונים רחבת ריקודים גדולה למסיבה של כל חיות היער." },
                    { title: "שלב בונוס: שביל הכוכבים", desc: "המסיבה נגמרה, וכדי לצאת מהיער נבנה את שביל הכוכבים הזוהר." }
                ]
            },
            ocean: { 
                name: "ממלכת אטלנטיס", char: "🧜‍♀️", themeColor: "blue",
                bg: (svg) => {
                    svg.innerHTML += `<defs><linearGradient id="g-o" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#bfdbfe"/><stop offset="100%" stop-color="#3b82f6"/></linearGradient></defs><rect width="100%" height="100%" fill="url(#g-o)" opacity="0.6"/><g class="float-obj"><circle cx="100" cy="150" r="10" fill="#60a5fa" opacity="0.4"/><circle cx="120" cy="120" r="15" fill="#60a5fa" opacity="0.4"/><circle cx="100" cy="80" r="8" fill="#60a5fa" opacity="0.3"/></g><path d="M 0 350 Q 150 300 250 350 T 500 330 L 500 400 L 0 400 Z" fill="#1d4ed8" opacity="0.2"/><path d="M 0 370 Q 200 320 300 370 T 500 350 L 500 400 L 0 400 Z" fill="#1e3a8a" opacity="0.2"/>`;
                },
                stages: [
                    { title: "שלב 1: שער העיר התת-ימית", desc: "צללנו למעמקים והגענו לאטלנטיס! עזרו לבנות את השער המגן כדי שניכנס בבטחה." },
                    { title: "שלב 2: ארמון האלמוגים", desc: "נכנסנו לעיר! עכשיו צריך לעזור למלך לשפץ את ארמון האלמוגים המלכותי." },
                    { title: "שלב 3: חומת הפנינים", desc: "הארמון מהמם, וסביבו ישנה חומה יקרה מפנינים שיש לתקן. מה ההיקף והשטח שלה?" },
                    { title: "שלב 4: תיבת האוצר השקועה", desc: "מעבר לחומה מצאנו תיבת אוצר עתיקה אבודה בקרקעית! חשבו את מידותיה." },
                    { title: "שלב 5: כס המלכות של פוסידון", desc: "הבאנו את האוצר למלך! כהוקרה, אנו מתקנים את כס המלכות של פוסידון." },
                    { title: "שלב בונוס: מזח הצוללות", desc: "המסע הושלם. בונים מזח לצוללת שלנו כדי לעלות בחזרה מעל פני הים." }
                ]
            },
            ninja: { 
                name: "כפר הנינג'ות", char: "🥷", themeColor: "rose",
                bg: (svg) => {
                    svg.innerHTML += `<defs><linearGradient id="g-n" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fecdd3"/><stop offset="100%" stop-color="#fb7185"/></linearGradient></defs><rect width="100%" height="100%" fill="url(#g-n)" opacity="0.6"/><circle cx="400" cy="120" r="60" fill="#e11d48" opacity="0.6" class="float-obj-slow"/><path d="M 0 400 L 150 200 L 300 400 Z" fill="#9f1239" opacity="0.3"/><path d="M 200 400 L 350 150 L 500 400 Z" fill="#881337" opacity="0.2"/>`;
                },
                stages: [
                    { title: "שלב 1: חומת האימונים", desc: "ברוכים הבאים לכפר הנינג'ות. התחלנו באימון הראשון: חשבו את חומת הטיפוס." },
                    { title: "שלב 2: מקדש הצללים", desc: "עברנו את החומה בהצלחה! כעת עלינו להתגנב למקדש הצללים. מהן המידות של המבנה?" },
                    { title: "שלב 3: זירת השוריקן", desc: "מתוך המקדש הגענו לזירת השוריקן. חשבו את מידות הזירה לאימון הקליעה." },
                    { title: "שלב 4: גשר הדרקון", desc: "האימון עבר מעולה. כדי להגיע לטירה צריך לחצות את גשר הדרקון העתיק." },
                    { title: "שלב 5: טירת השוגון", desc: "המשימה האחרונה! אנחנו בטירת השוגון. פתרו את חידת השטח כדי להפוך למאסטר." },
                    { title: "שלב בונוס: חדר הסודות", desc: "קיבלתם תואר מאסטר נינג'ה! כנסו לחדר הסודות וחשבו את ההיקף." }
                ]
            },
            dino: { 
                name: "פארק הדינוזאורים", char: "🦖", themeColor: "amber",
                bg: (svg) => {
                    svg.innerHTML += `<defs><linearGradient id="g-d" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fef3c7"/><stop offset="100%" stop-color="#f59e0b"/></linearGradient></defs><rect width="100%" height="100%" fill="url(#g-d)" opacity="0.5"/><path d="M 0 350 Q 100 250 250 350 T 500 300 L 500 400 L 0 400 Z" fill="#b45309" opacity="0.3"/><g opacity="0.6" class="float-obj-slow"><path d="M 350 250 L 360 180 L 370 250 Z" fill="#78350f" /><path d="M 330 270 L 340 200 L 350 270 Z" fill="#78350f" /></g>`;
                },
                stages: [
                    { title: "שלב 1: גדר הטי-רקס", desc: "הגענו לפארק היורה! משימה ראשונה - ודאו את המידות של הגדר כדי שיהיה בטוח." },
                    { title: "שלב 2: מתחם הבקיעה", desc: "הגדרות מאובטחות והדינוזאורים בוקעים. עזרו לחשב את שטח המדגרה." },
                    { title: "שלב 3: שער הפארק הענק", desc: "הדינוזאורים גדלו ושער הכניסה זקוק לחיזוקים. פתרו את חידת הצלעות." },
                    { title: "שלב 4: גשר התצפית", desc: "אחרי שחיזקנו את השער, בונים גשר חדש מעל אגם המים לתצפית." },
                    { title: "שלב 5: מרכז המבקרים", desc: "המשימה הסופית! מרכז המבקרים של הפארק נפתח לחגיגה, השלימו חישובים אחרונים." },
                    { title: "שלב בונוס: מסלול הג'יפים", desc: "הפארק פתוח! שרטטו את מסלול הג'יפים החדש מסביב לדינוזאורים." }
                ]
            }
        };

        function updateTheme(world, stageIndex) {
            const theme = themeMaps[world.themeColor] || themeMaps.indigo;
            const sp = document.getElementById('story-panel');
            sp.className = `w-full p-6 rounded-[2.5rem] border relative overflow-hidden transition-colors duration-500 ${theme.light} ${theme.border} text-right panel-3d`;
            document.getElementById('story-blob').className = `absolute top-0 right-0 w-40 h-40 rounded-full -mr-20 -mt-20 opacity-40 transition-colors duration-500 ${theme.bg}`;
            document.getElementById('story-title').className = `text-2xl font-black mb-2 flex items-center gap-3 justify-start w-fit ${theme.text}`;
            document.getElementById('story-desc').className = `font-bold text-lg leading-relaxed transition-colors duration-500 max-w-4xl ${theme.text}`;
            document.getElementById('story-char').textContent = world.char;
            document.getElementById('walker-char').textContent = world.char;
            document.getElementById('btn-char-p').textContent = world.char;
            document.getElementById('btn-char-a').textContent = world.char;
            
            const stage = world.stages[stageIndex % world.stages.length];
            document.getElementById('story-title-text').textContent = stage.title;
            document.getElementById('story-desc').textContent = stage.desc;
        }

        // --- Shape Generation Functions ---
        function genLShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*6); let h1 = 3 + Math.floor(Math.random()*5); 
            let w2 = 3 + Math.floor(Math.random()*6); let h2 = 4 + Math.floor(Math.random()*5); 
            let sides = [
                { x: w1/2, y: 0, val: w1, id: 't1', pos: 'top' },
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'right' },
                { x: w1+w2/2, y: h1, val: w2, id: 't2', pos: 'top' },
                { x: w1+w2, y: h1+h2/2, val: h2, id: 'r', pos: 'right' },
                { x: (w1+w2)/2, y: h1+h2, val: w1+w2, id: 'b', pos: 'bottom' },
                { x: 0, y: (h1+h2)/2, val: h1+h2, id: 'l', pos: 'left' }
            ];
            
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = w2; sides[2].parts = ['b', 't1']; sides[2].op = '-'; }
            if (diff >= 2) { sides[5].type = 'missing'; sides[5].correct = h1+h2; sides[5].parts = ['r', 'il']; sides[5].op = '+'; }

            return {
                points: [[0,0], [w1,0], [w1,h1], [w1+w2,h1], [w1+w2,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}], rects: [{x:0, y:0, w:w1, h:h1+h2, fill: "#bae6fd", labelX: w1/2, labelY: (h1+h2)/2}, {x:w1, y:h1, w:w2, h:h2, fill: "#bbf7d0", labelX: w1+w2/2, labelY: h1+h2/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1, y2:h1}], rects: [{x:0, y:0, w:w1, h:h1, fill: "#bae6fd", labelX: w1/2, labelY: h1/2}, {x:0, y:h1, w:w1+w2, h:h2, fill: "#bbf7d0", labelX: (w1+w2)/2, labelY: h1+h2/2}] }
                ],
                ansP: (w1+w2+h1+h2)*2, ansA: (w1*(h1+h2)) + (w2*h2)
            };
        }

        function genStairShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*5); let h1 = 3 + Math.floor(Math.random()*4); 
            let w2 = 4 + Math.floor(Math.random()*6); let h2 = 3 + Math.floor(Math.random()*4); 
            let sides = [
                { x: w1/2, y: h1, val: w1, id: 'ib', pos: 'top' }, 
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'left' },
                { x: w1+w2/2, y: 0, val: w2, id: 't', pos: 'top' }, 
                { x: w1+w2, y: (h1+h2)/2, val: h1+h2, id: 'r', pos: 'right' },
                { x: (w1+w2)/2, y: h1+h2, val: w1+w2, id: 'b', pos: 'bottom'}, 
                { x: 0, y: h1+h2/2, val: h2, id: 'l', pos: 'left'}
            ];
            
            if (diff >= 1) { sides[0].type = 'missing'; sides[0].correct = w1; sides[0].parts = ['b', 't']; sides[0].op='-'; }
            if (diff >= 2) { sides[3].type = 'missing'; sides[3].correct = h1+h2; sides[3].parts = ['l', 'il']; sides[3].op='+'; }

            return {
                points: [[0,h1], [w1,h1], [w1,0], [w1+w2,0], [w1+w2,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}], rects: [{x:0, y:h1, w:w1, h:h2, fill: "#fef3c7", labelX: w1/2, labelY: h1+h2/2}, {x:w1, y:0, w:w2, h:h1+h2, fill: "#bbf7d0", labelX: w1+w2/2, labelY: (h1+h2)/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1+w2, y2:h1}], rects: [{x:0, y:h1, w:w1+w2, h:h2, fill: "#fef3c7", labelX: (w1+w2)/2, labelY: h1+h2/2}, {x:w1, y:0, w:w2, h:h1, fill: "#bbf7d0", labelX: w1+w2/2, labelY: h1/2}] }
                ],
                ansP: (w1+w2+h1+h2)*2, ansA: (w1*h2) + (w2*(h1+h2))
            };
        }

        function genUShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*3), w2 = 3 + Math.floor(Math.random()*4), w3 = 3 + Math.floor(Math.random()*3), h1 = 3 + Math.floor(Math.random()*4), h2 = 2 + Math.floor(Math.random()*3);
            let sides = [
                { x: w1/2, y: 0, val: w1, id: 't1', pos: 'top' }, 
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'right' },
                { x: w1+w2/2, y: h1, val: w2, id: 'ib', pos: 'top' }, 
                { x: w1+w2, y: h1/2, val: h1, id: 'ir', pos: 'left' },
                { x: w1+w2+w3/2, y: 0, val: w3, id: 't2', pos: 'top' }, 
                { x: w1+w2+w3, y: (h1+h2)/2, val: h1+h2, id: 'r', pos: 'right' },
                { x: (w1+w2+w3)/2, y: h1+h2, val: w1+w2+w3, id: 'b', pos: 'bottom' }, 
                { x: 0, y: (h1+h2)/2, val: h1+h2, id: 'l', pos: 'left' }
            ];
            
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = w2; sides[2].parts = ['b', 't1', 't2']; sides[2].op='-'; }
            if (diff >= 2) { sides[7].type = 'missing'; sides[7].correct = h1+h2; sides[7].parts = ['r']; sides[7].op='='; } 

            return {
                points: [[0,0], [w1,0], [w1,h1], [w1+w2,h1], [w1+w2,0], [w1+w2+w3,0], [w1+w2+w3,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}, {x1:w1+w2, y1:h1, x2:w1+w2, y2:h1+h2}], rects: [{x:0, y:0, w:w1, h:h1+h2, fill: "#bae6fd", labelX: w1/2, labelY: (h1+h2)/2}, {x:w1, y:h1, w:w2, h:h2, fill: "#fef3c7", labelX: w1+w2/2, labelY: h1+h2/2}, {x:w1+w2, y:0, w:w3, h:h1+h2, fill: "#bbf7d0", labelX: w1+w2+w3/2, labelY: (h1+h2)/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1, y2:h1}, {x1:w1+w2, y1:h1, x2:w1+w2+w3, y2:h1}], rects: [{x:0, y:0, w:w1, h:h1, fill: "#bae6fd", labelX: w1/2, labelY: h1/2}, {x:0, y:h1, w:w1+w2+w3, h:h2, fill: "#fef3c7", labelX: (w1+w2+w3)/2, labelY: h1+h2/2}, {x:w1+w2, y:0, w:w3, h:h1, fill: "#bbf7d0", labelX: w1+w2+w3/2, labelY: h1/2}] }
                ],
                ansP: (w1+w2+w3+h1+h2)*2 + (h1*2), ansA: (w1*(h1+h2)) + (w2*h2) + (w3*(h1+h2))
            };
        }

        function genPlusShape(diff) {
            let w = 3 + Math.floor(Math.random()*3), h = 3 + Math.floor(Math.random()*4);
            let sides = [
                { x: w*1.5, y: 0, val: w, id: 't', pos: 'top' }, 
                { x: w*2, y: h*0.5, val: h, id: 'tr1', pos: 'right' },
                { x: w*2.5, y: h, val: w, id: 'r1', pos: 'top' }, 
                { x: w*3, y: h*1.5, val: h, id: 'r2', pos: 'right' },
                { x: w*2.5, y: h*2, val: w, id: 'r3', pos: 'bottom' }, 
                { x: w*2, y: h*2.5, val: h, id: 'br1', pos: 'right' },
                { x: w*1.5, y: h*3, val: w, id: 'b', pos: 'bottom' }, 
                { x: w, y: h*2.5, val: h, id: 'bl1', pos: 'left' },
                { x: w*0.5, y: h*2, val: w, id: 'l3', pos: 'bottom' }, 
                { x: 0, y: h*1.5, val: h, id: 'l2', pos: 'left' },
                { x: w*0.5, y: h, val: w, id: 'l1', pos: 'top' }, 
                { x: w, y: h*0.5, val: h, id: 'tl1', pos: 'left' }
            ];
            
            if (diff >= 1) { sides[0].type = 'missing'; sides[0].correct = w; sides[0].parts = ['b']; sides[0].op = '='; }
            if (diff >= 2) { sides[3].type = 'missing'; sides[3].correct = h; sides[3].parts = ['l2']; sides[3].op = '='; }
            if (diff >= 3) { sides[6].type = 'missing'; sides[6].correct = w; sides[6].parts = ['t']; sides[6].op = '='; }

            return {
                points: [[w,0], [w*2,0], [w*2,h], [w*3,h], [w*3,h*2], [w*2,h*2], [w*2,h*3], [w,h*3], [w,h*2], [0,h*2], [0,h], [w,h]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w, y1:h, x2:w, y2:h*2}, {x1:w*2, y1:h, x2:w*2, y2:h*2}], rects: [{x:w, y:0, w:w, h:h*3, fill: "#bbf7d0", labelX: w*1.5, labelY: h*1.5}, {x:0, y:h, w:w, h:h, fill: "#bae6fd", labelX: w*0.5, labelY: h*1.5}, {x:w*2, y:h, w:w, h:h, fill: "#fef3c7", labelX: w*2.5, labelY: h*1.5}] },
                    { id: 'd2', lines: [{x1:w, y1:h, x2:w*2, y2:h}, {x1:w, y1:h*2, x2:w*2, y2:h*2}], rects: [{x:0, y:h, w:w*3, h:h, fill: "#bae6fd", labelX: w*1.5, labelY: h*1.5}, {x:w, y:0, w:w, h:h, fill: "#bbf7d0", labelX: w*1.5, labelY: h*0.5}, {x:w, y:h*2, w:w, h:h, fill: "#fef3c7", labelX: w*1.5, labelY: h*2.5}] }
                ],
                ansP: w*4 + h*8, ansA: (w*w)*5
            };
        }

        function genSimpleRect() {
            let w = 5 + Math.floor(Math.random()*8); let h = 4 + Math.floor(Math.random()*6);
            return {
                points: [[0,0], [w,0], [w,h], [0,h]],
                sides: [{x:w/2, y:0, val:w, id:'t', pos:'top'}, {x:w, y:h/2, val:h, id:'r', pos:'right'}, {x:w/2, y:h, val:w, id:'b', pos:'bottom'}, {x:0, y:h/2, val:h, id:'l', pos:'left'}],
                dividers: [], rects: [{x:0, y:0, w:w, h:h, fill: "#bae6fd", labelX: w/2, labelY: h/2}], ansP: (w+h)*2, ansA: w*h
            };
        }

        function genParallelogram(diff) {
            let b = 6 + Math.floor(Math.random()*6); let side = 5 + Math.floor(Math.random()*3);
            let sides = [
                {x: b/2 + 2, y: 0, val: b, id: 't', pos: 'top'}, 
                {x: b + 1, y: 2, val: side, id: 'r', pos: 'right'},
                {x: b/2, y: 4, val: b, id: 'b', pos: 'bottom'}, 
                {x: 1, y: 2, val: side, id: 'l', pos: 'left'}
            ];
            if (diff >= 1) { sides[0].type = 'missing'; sides[0].correct = b; sides[0].parts = ['b']; sides[0].op = '='; }
            if (diff >= 2) { sides[3].type = 'missing'; sides[3].correct = side; sides[3].parts = ['r']; sides[3].op = '='; }
            return { points: [[2,0], [b+2,0], [b,4], [0,4]], sides: sides, dividers: [], rects: [], ansP: (b+side)*2, ansA: null };
        }

        function genRhombus(diff) {
            let a = 5 + Math.floor(Math.random()*7);
            let sides = [
                {x: 6, y: 1.5, val: a, id: 'tr', pos: 'right'}, 
                {x: 6, y: 4.5, val: a, id: 'br', pos: 'right'},
                {x: 2, y: 4.5, val: a, id: 'bl', pos: 'left'}, 
                {x: 2, y: 1.5, val: a, id: 'tl', pos: 'left'}
            ];
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = a; sides[2].parts = ['tr']; sides[2].op = '='; }
            if (diff >= 2) { sides[0].type = 'missing'; sides[0].correct = a; sides[0].parts = ['bl']; sides[0].op = '='; }
            return { points: [[4,0], [8,3], [4,6], [0,3]], sides: sides, dividers: [], rects: [], ansP: a*4, ansA: null };
        }

        function genIsoscelesTrapezoid(diff) {
            let top = 4 + Math.floor(Math.random()*5); let bottom = top + 4; let leg = 5 + Math.floor(Math.random()*4);
            let sides = [
                {x: 5, y: 0, val: top, id: 't', pos: 'top'}, 
                {x: 5 + top/2 + 1, y: 2, val: leg, id: 'r', pos: 'right'},
                {x: 5, y: 4, val: bottom, id: 'b', pos: 'bottom'}, 
                {x: 5 - top/2 - 1, y: 2, val: leg, id: 'l', pos: 'left'}
            ];
            if (diff >= 1) { sides[3].type = 'missing'; sides[3].correct = leg; sides[3].parts = ['r']; sides[3].op = '='; }
            return { points: [[5 - top/2, 0], [5 + top/2, 0], [5 + bottom/2, 4], [5 - bottom/2, 4]], sides: sides, dividers: [], rects: [], ansP: top + bottom + leg*2, ansA: null };
        }

        function genKite(diff) {
            let t_leg = 4 + Math.floor(Math.random()*4), b_leg = 7 + Math.floor(Math.random()*5);
            let sides = [
                {x: 4.5, y: 1.5, val: t_leg, id: 'tr', pos: 'right'}, 
                {x: 4.5, y: 6.5, val: b_leg, id: 'br', pos: 'right'},
                {x: 1.5, y: 6.5, val: b_leg, id: 'bl', pos: 'left'}, 
                {x: 1.5, y: 1.5, val: t_leg, id: 'tl', pos: 'left'}
            ];
            if (diff >= 1) { sides[3].type = 'missing'; sides[3].correct = t_leg; sides[3].parts = ['tr']; sides[3].op = '='; }
            if (diff >= 2) { sides[1].type = 'missing'; sides[1].correct = b_leg; sides[1].parts = ['bl']; sides[1].op = '='; }
            return { points: [[3,0], [6,3], [3,10], [0,3]], sides: sides, dividers: [], rects: [], ansP: (t_leg + b_leg)*2, ansA: null };
        }

        function genEquilateralTriangle(diff) {
            let a = 6 + Math.floor(Math.random()*8);
            let sides = [
                {x: 4.5, y: 2.5, val: a, id: 'r', pos: 'right'}, 
                {x: 3, y: 5.5, val: a, id: 'b', pos: 'bottom'}, 
                {x: 1.5, y: 2.5, val: a, id: 'l', pos: 'left'}
            ];
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = a; sides[2].parts = ['b']; sides[2].op = '='; }
            if (diff >= 2) { sides[0].type = 'missing'; sides[0].correct = a; sides[0].parts = ['l']; sides[0].op = '='; }
            return { points: [[3,0], [6,5], [0,5]], sides: sides, dividers: [], rects: [], ansP: a*3, ansA: null };
        }

        function genRightTriangle(diff) {
            let w = 4 + Math.floor(Math.random()*4), h = 3 + Math.floor(Math.random()*4), hyp = Math.round(Math.sqrt(w*w + h*h));
            let sides = [
                {x: 0, y: 1.5, val: h, id: 'l', pos: 'left'}, 
                {x: 2, y: 3.5, val: w, id: 'b', pos: 'bottom'}, 
                {x: 2.5, y: 1.5, val: hyp, id: 'hyp', pos: 'right'}
            ];
            return { points: [[0,0], [0,3], [4,3]], sides: sides, dividers: [], rects: [], ansP: w + h + hyp, ansA: null };
        }

        // --- Setup Game ---
        document.getElementById('start-game-btn').onclick = () => {
            initAudio();
            const name = document.getElementById('player-name-input').value.trim();
            if(name) playerName = name;
            MAX_LEVELS = parseInt(document.getElementById('levels-select').value);
            selectedStoryId = document.getElementById('story-select').value;
            
            AVAILABLE_GENERATORS = [];
            if(document.getElementById('chk-comp').checked) AVAILABLE_GENERATORS.push(genLShape, genStairShape, genUShape, genPlusShape);
            if(document.getElementById('chk-simple').checked) AVAILABLE_GENERATORS.push(genSimpleRect);
            if(document.getElementById('chk-triangles').checked) AVAILABLE_GENERATORS.push(genRightTriangle, genEquilateralTriangle);
            if(document.getElementById('chk-quads').checked) AVAILABLE_GENERATORS.push(genParallelogram, genRhombus, genIsoscelesTrapezoid, genKite);
            
            if(AVAILABLE_GENERATORS.length === 0) AVAILABLE_GENERATORS.push(genLShape);

            const pNameDisp = document.getElementById('player-name-display');
            if (pNameDisp) pNameDisp.textContent = playerName;
            
            document.querySelectorAll('.player-name-text').forEach(e => e.textContent = playerName);
            document.getElementById('welcome-modal').classList.add('hidden');
            document.getElementById('scratchpad').classList.remove('hidden');
            
            gameStarted = true; cur = 0; levelsCache = []; coins = 0;
            addCoins(0);
            init();
        };

        function getLevel(index) {
            if(!levelsCache[index]) {
                const gen = AVAILABLE_GENERATORS[index % AVAILABLE_GENERATORS.length];
                let l = gen(difficulty);
                let maxX=0, maxY=0; l.points.forEach(p=>{if(p[0]>maxX) maxX=p[0]; if(p[1]>maxY) maxY=p[1];});
                
                let grid = Math.min(320/maxX, 220/maxY);
                l.grid = grid; 
                l.offX = (500 - maxX*grid)/2; 
                l.offY = (400 - maxY*grid)/2 + 20;
                levelsCache[index] = l;
            }
            return levelsCache[index];
        }

        function init() {
            if(!gameStarted || cur >= MAX_LEVELS) {
                if(cur >= MAX_LEVELS) {
                    playSound('tada');
                    document.getElementById('report-modal').classList.remove('hidden');
                }
                return;
            }
            // Cleanup previous level floating elements completely!
            document.querySelectorAll('.add-helper').forEach(e => e.remove());
            activeDivId = null;
            isWalking = false;
            walkStepResolver = null;

            const world = STORIES[selectedStoryId];
            const level = getLevel(cur);
            
            const helpTextSpan = document.getElementById('help-text-span');
            helpTextSpan.textContent = cur > 0 ? "עזרה (10)" : "עזרה (חינם)";

            if(helpCooldownTimerId) clearTimeout(helpCooldownTimerId);
            if(cooldownInterval) clearInterval(cooldownInterval);
            helpEnabled = false; helpOnCooldown = false;
            
            const helpBtn = document.getElementById('toggle-help-btn');
            helpBtn.classList.remove('grayscale-0');
            helpBtn.style.opacity = '1';
            helpBtn.style.cursor = 'pointer';
            document.getElementById('help-icon-span').innerHTML = '<svg class="w-6 h-6"><use href="#icon-bulb"></use></svg>';
            document.getElementById('help-indicator').classList.add('hidden');
            
            updateTheme(world, cur);
            
            document.getElementById('level-num').textContent = cur + 1;
            document.getElementById('progress-bar').style.width = `${(cur/MAX_LEVELS)*100}%`;
            document.getElementById('p-final').value = '';
            document.getElementById('a-final').value = '';
            document.getElementById('p-inputs').innerHTML = '<div class="text-slate-400 text-sm font-bold w-full text-right mb-2" dir="rtl">מספרים שייאספו בטיול:</div>';
            
            const areaPanel = document.getElementById('area-panel-container');
            if (level.ansA === null || level.ansA === undefined) {
                areaPanel.classList.add('hidden');
            } else {
                areaPanel.classList.remove('hidden');
                document.getElementById('a-inputs').innerHTML = '<div class="text-indigo-800 bg-indigo-50 border-2 border-dashed border-indigo-300 p-4 rounded-xl text-center font-black animate-pulse transition-all">✂️ לחצו על אחד מהקווים הכתומים המקווקווים כדי לחלק את הצורה!</div>';
                document.getElementById('composite-final-area').classList.add('hidden');
                if(level.dividers.length === 0) { 
                    document.getElementById('a-inputs').innerHTML = '';
                    selectDivider({id: 'dummy', rects: level.rects, lines: []});
                }
            }

            document.getElementById('interactive-overlay').innerHTML = '';
            document.getElementById('status-msg').classList.add('hidden');
            document.getElementById('p-status-msg').classList.add('hidden');
            document.getElementById('a-status-msg').classList.add('hidden');
            
            const svg = document.getElementById('game-svg');
            svg.innerHTML = '';
            
            const defs = document.createElementNS("http://www.w3.org/2000/svg", "defs");
            defs.innerHTML = `
                <filter id="shape-shadow" x="-10%" y="-10%" width="120%" height="120%">
                    <feDropShadow dx="0" dy="15" stdDeviation="10" flood-color="#0f172a" flood-opacity="0.3"/>
                </filter>`;
            svg.appendChild(defs);

            if(world.bg) world.bg(svg);

            const dStr = "M " + level.points.map(p => `${level.offX + p[0]*level.grid},${level.offY + p[1]*level.grid}`).join(" L ") + " Z";
            const shape = document.createElementNS("http://www.w3.org/2000/svg", "path");
            shape.setAttribute('d', dStr); 
            shape.setAttribute('fill', 'rgba(255, 255, 255, 0.95)'); 
            shape.setAttribute('stroke', '#0f172a'); 
            shape.setAttribute('stroke-width', '6');
            shape.setAttribute('stroke-linejoin', 'round');
            shape.setAttribute('filter', 'url(#shape-shadow)');
            svg.appendChild(shape);

            const rectGroup = document.createElementNS("http://www.w3.org/2000/svg", "g");
            rectGroup.setAttribute("id", "area-rects-group");
            svg.appendChild(rectGroup);

            if(level.dividers) {
                level.dividers.forEach(div => {
                    div.lines.forEach(l => {
                        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                        line.setAttribute('x1', level.offX + l.x1*level.grid); line.setAttribute('y1', level.offY + l.y1*level.grid);
                        line.setAttribute('x2', level.offX + l.x2*level.grid); line.setAttribute('y2', level.offY + l.y2*level.grid);
                        line.setAttribute('class', `divider-line div-${div.id}`);
                        line.onclick = () => selectDivider(div);
                        svg.appendChild(line);
                    });
                });
            }

            const overlay = document.getElementById('interactive-overlay');
            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
            level.sides.forEach(s => {
                const div = document.createElement('div');
                div.className = 'side-label';
                
                let svgX = level.offX + s.x*level.grid;
                let svgY = level.offY + s.y*level.grid;
                
                // מרחק מאוזן מחוץ לצורה
                if(s.pos === 'top') svgY -= 35;
                if(s.pos === 'bottom') svgY += 35;
                if(s.pos === 'left') svgX -= 35;
                if(s.pos === 'right') svgX += 35;

                div.style.left = `${svgX * (bbox.width/500)}px`;
                div.style.top = `${svgY * (bbox.height/400)}px`;
                
                const safe = JSON.stringify(s).replace(/"/g, '&quot;');
                
                if(s.type === 'missing') {
                    div.innerHTML = `<button id="btn-${s.id}" class="side-input-btn animate-pulse relative z-20" onclick="openAddHelper(this, '${safe}')">?</button>`;
                } else {
                    div.innerHTML = `<div id="val-${s.id}" class="bg-white border-2 border-slate-300 px-2.5 py-0.5 rounded-xl font-black text-slate-800 shadow-sm relative z-20 border-b-4 cursor-default">${s.val}</div>`;
                }
                overlay.appendChild(div);
            });
            renderStars();
        }

        // --- Help & Cooldown ---
        document.getElementById('toggle-help-btn').onclick = () => {
            const btn = document.getElementById('toggle-help-btn');
            
            if (helpOnCooldown) {
                playSound('step');
                document.getElementById('buyout-modal').classList.remove('hidden');
                return;
            }

            if (!helpEnabled && cur > 0) {
                if (coins < 10) {
                    playSound('error');
                    showMsg("אין לכם מספיק מטבעות להפעלת העזרה! (עולה 10 מטבעות)", "red");
                    return;
                }
                addCoins(-10);
            }

            helpEnabled = !helpEnabled;
            playSound('step');
            btn.classList.toggle('grayscale-0', helpEnabled);
            document.getElementById('help-indicator').classList.toggle('hidden', !helpEnabled);

            if (!helpEnabled) {
                document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            }

            if (cur > 0) {
                if (helpEnabled) {
                    showMsg("💡 העזרה הופעלה ל-15 שניות בלבד! נצלו אותה מהר.", "green");
                    helpTimeoutId = setTimeout(() => {
                        turnOffHelpAndCooldown(btn);
                    }, 15000);
                } else {
                    clearTimeout(helpTimeoutId);
                    turnOffHelpAndCooldown(btn);
                }
            }
        };

        function turnOffHelpAndCooldown(btn) {
            helpEnabled = false;
            btn.classList.remove('grayscale-0');
            document.getElementById('help-indicator').classList.add('hidden');
            document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            
            helpOnCooldown = true;
            cooldownSeconds = 20;
            btn.style.opacity = '0.7';
            
            document.getElementById('help-icon-span').innerHTML = `<span class="text-xl">⏳${cooldownSeconds}</span>`;
            document.getElementById('help-text-span').innerHTML = "דלג (-20)";
            document.getElementById('help-text-span').classList.add('text-amber-600');
            showMsg("העזרה כבויה ונחה. המתינו או לחצו כדי לדלג תמורת מטבעות! ⏳", "red");
            
            cooldownInterval = setInterval(() => {
                cooldownSeconds--;
                if(cooldownSeconds <= 0) {
                    clearInterval(cooldownInterval);
                    finishCooldown(btn);
                } else {
                    document.getElementById('help-icon-span').innerHTML = `<span class="text-xl">⏳${cooldownSeconds}</span>`;
                }
            }, 1000);
        }

        function finishCooldown(btn) {
            helpOnCooldown = false;
            btn.style.opacity = '1';
            document.getElementById('help-icon-span').innerHTML = '<svg class="w-6 h-6"><use href="#icon-bulb"></use></svg>';
            document.getElementById('help-text-span').innerHTML = "עזרה (10)";
            document.getElementById('help-text-span').classList.remove('text-amber-600');
            showMsg("העזרה חזרה! תוכלו להשתמש בה שוב אם חייבים 💡", "green");
        }

        window.buyoutCooldown = () => {
            if(coins >= 20) {
                addCoins(-20);
                playSound('tada');
                document.getElementById('buyout-modal').classList.add('hidden');
                clearInterval(cooldownInterval);
                finishCooldown(document.getElementById('toggle-help-btn'));
            } else {
                playSound('error');
                showMsg("אין לכם מספיק מטבעות לדילוג! נדרשים 20 מטבעות.", "red");
                document.getElementById('buyout-modal').classList.add('hidden');
            }
        };

        // --- Popup Calculator (Sides) ---
        window.openAddHelper = (el, dataStr) => {
            document.querySelectorAll('.add-helper').forEach(e => e.remove());
            document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));

            playSound('step');
            const side = JSON.parse(dataStr.replace(/&quot;/g, '"'));
            const level = getLevel(cur);
            
            if(helpEnabled && side.parts) {
                side.parts.forEach(pid => {
                    const pel = document.getElementById('val-' + pid);
                    if(pel) pel.classList.add('highlight-parallel');
                });
            }

            const cleanupFn = () => {
                document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            };

            const helper = document.createElement('div');
            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
            const relY = el.parentElement.offsetTop / bbox.height;
            const relX = el.parentElement.offsetLeft / bbox.width;
            
            let posClass = 'helper-top';
            if(relY < 0.2) posClass = 'helper-bottom';
            else if(relX < 0.2) posClass = 'helper-right';
            else if(relX > 0.8) posClass = 'helper-left';
            
            helper.className = `add-helper ${posClass}`;
            helper.dir = 'ltr';
            
            const closeX = document.createElement('div'); closeX.className = 'close-x'; closeX.textContent = '✕';
            closeX.onclick = (ev) => { ev.stopPropagation(); cleanupFn(); helper.remove(); };
            helper.appendChild(closeX);

            const vBtn = document.createElement('button');
            vBtn.className = 'bg-blue-600 hover:bg-blue-700 text-white w-10 h-10 rounded-lg font-black ml-2 transition btn-3d shadow-md border-blue-800 flex-shrink-0';
            vBtn.textContent = 'V';
            
            vBtn.onclick = () => {
                if(side.type === 'missing') confirmSide(helper, side, cleanupFn, el.parentElement);
                else { playSound('step'); cleanupFn(); helper.remove(); }
            };
            helper.appendChild(vBtn);

            const total = document.createElement('input'); 
            total.type = 'number'; total.className = 'total-v shadow-sm'; 
            
            total.placeholder = side.type === 'missing' ? "?" : side.val; 
            if(side.val && side.type !== 'missing') {
                total.value = side.val;
                total.readOnly = true; 
            }
            
            total.onkeydown = (e) => { if(e.key === 'Enter') vBtn.click(); };
            helper.appendChild(total);

            const partsArr = side.parts || [];
            if (partsArr.length > 0) {
                const eq = document.createElement('span'); eq.className = 'font-black text-blue-600 mx-1'; eq.textContent = '=';
                helper.appendChild(eq);
                
                partsArr.forEach((pid, i) => {
                    const ps = level.sides.find(x => x.id === pid);
                    const btn = document.createElement('button');
                    btn.className = 'part-v-btn relative flex items-center justify-center group';
                    
                    let isRevealed = false;
                    if (helpEnabled && ps && !ps.type) { 
                        isRevealed = true;
                    }

                    if (isRevealed) {
                        btn.className = 'part-v-btn revealed';
                        btn.textContent = ps ? ps.val : '?';
                    } else {
                        btn.innerHTML = `
                            <span class="text-slate-400 font-bold text-xl">?</span>
                            <div class="absolute -top-2 -right-2 bg-amber-100 border border-amber-400 rounded-full w-5 h-5 flex items-center justify-center text-[11px] hidden group-hover:flex shadow-sm z-10" title="גלה צלע (2 מטבעות)">🪙</div>
                        `;
                        btn.onclick = (e) => {
                            e.preventDefault();
                            if (isRevealed) return;
                            if (coins >= 2) {
                                addCoins(-2);
                                playSound('success');
                                isRevealed = true;
                                btn.className = 'part-v-btn revealed';
                                btn.style.animation = 'popIn 0.3s ease-out';
                                btn.textContent = ps ? ps.val : '?';
                                
                                const pel = document.getElementById('val-' + pid);
                                if(pel) {
                                    pel.classList.add('highlight-parallel');
                                    setTimeout(() => pel.classList.remove('highlight-parallel'), 2000);
                                }
                            } else {
                                showMsg('אין מספיק מטבעות! פתיחת ריבוע עולה 2 מטבעות.', 'red');
                                playSound('error');
                            }
                        };
                    }
                    
                    helper.appendChild(btn);
                    if(i < partsArr.length - 1) {
                        const op = document.createElement('span'); op.className = 'font-black px-1 text-slate-500'; op.textContent = side.op || '+';
                        helper.appendChild(op);
                    }
                });
            }
            
            el.parentElement.appendChild(helper);
            setTimeout(() => total.focus(), 50);
        };

        function confirmSide(helper, side, cleanupFn, container) {
            const totalInp = helper.querySelector('.total-v');
            const val = parseInt(totalInp.value);
            
            if(val === side.correct) {
                playSound('success');
                addCoins(10);
                const safe = JSON.stringify({...side, type: null, val: val}).replace(/"/g, '&quot;');
                container.innerHTML = `<div id="val-${side.id}" class="bg-green-100 border-2 border-green-500 px-2.5 py-0.5 rounded-xl font-black text-green-800 shadow-sm relative z-20 border-b-4 cursor-default">${val}</div>`;
                cleanupFn();
                document.getElementById('status-msg').classList.add('hidden'); 
            } else {
                playSound('error');
                totalInp.classList.add('shake-err'); setTimeout(()=>totalInp.classList.remove('shake-err'), 400);
            }
        }

        async function startWalk(type) {
            if(isWalking) return;
            const level = getLevel(cur);
            if(document.querySelectorAll('.side-input-btn').length > 0) {
                playSound('error');
                return showMsg("גלו קודם את כל הצלעות החסרות עם סימני השאלה!", "red");
            }
            isWalking = true;
            const walker = document.getElementById('knight-walker');
            const bubble = document.getElementById('knight-bubble');
            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
            const px = (x) => (level.offX + x*level.grid)*(bbox.width/500);
            const py = (y) => (level.offY + y*level.grid)*(bbox.height/400);

            if(type === 'perimeter') {
                walker.classList.remove('hidden');
                let sum = 0;
                const pInputs = document.getElementById('p-inputs');
                pInputs.innerHTML = '<div class="text-slate-400 text-sm font-bold w-full text-right mb-2" dir="rtl">מספרים שנאספו בטיול:</div>';
                
                for(let i=0; i<level.points.length; i++) {
                    playSound('step');
                    const p1 = level.points[i]; const p2 = level.points[(i+1)%level.points.length];
                    const len = (level.sides[i] && level.sides[i].val) ? level.sides[i].val : Math.round(Math.sqrt(Math.pow(p1[0]-p2[0],2) + Math.pow(p1[1]-p2[1],2)));
                    walker.style.transition = i === 0 ? 'none' : 'left 0.8s linear, top 0.8s linear';
                    walker.style.left = `${px(p2[0])}px`; walker.style.top = `${py(p2[1])}px`;
                    
                    if (helpEnabled) {
                        bubble.innerHTML = i===0 ? `צלע באורך <b>${len}</b>` : `<span dir="ltr">${sum} + ${len}</span> = <b>${sum+len}</b>`;
                        await new Promise(r => setTimeout(r, 1200));
                        sum += len;
                    } else {
                        bubble.innerHTML = i===0 ? `אורך <b>${len}</b><br><div class="mt-2 flex items-center justify-center gap-1">סה"כ: <input type="number" id="walk-inp" class="walk-inp-style border-indigo-500" onkeydown="if(event.key==='Enter') window.checkWalkStep(${len})"> <button onclick="window.checkWalkStep(${len})" class="walk-btn-style">V</button></div>` : `<span dir="ltr">${sum} + ${len}</span> = <br><div class="mt-2 flex items-center justify-center gap-1"><input type="number" id="walk-inp" class="walk-inp-style border-indigo-500" onkeydown="if(event.key==='Enter') window.checkWalkStep(${sum+len})"> <button onclick="window.checkWalkStep(${sum+len})" class="walk-btn-style">V</button></div>`;
                        setTimeout(() => document.getElementById('walk-inp')?.focus(), 50); 
                        await new Promise(resolve => { walkStepResolver = resolve; });
                        sum += len;
                    }

                    const box = document.createElement('div'); box.className = 'perimeter-box'; box.textContent = len;
                    pInputs.appendChild(box);
                    if(i < level.points.length - 1) {
                        const plus = document.createElement('span'); plus.className='font-black text-blue-400 text-xl'; plus.textContent='+';
                        pInputs.appendChild(plus);
                    }
                }
                
                playSound('success');
                let centerX = 0, centerY = 0;
                level.points.forEach(p => { centerX += p[0]; centerY += p[1]; });
                centerX /= level.points.length; centerY /= level.points.length;
                walker.style.left = `${px(centerX)}px`; walker.style.top = `${py(centerY)}px`;
                bubble.innerHTML = `הגענו לסוף! <br>עכשיו הקלידו את התשובה הסופית למטה.`;
                setTimeout(() => { walker.classList.add('hidden'); isWalking = false; }, 3000);
            
            } else if (type === 'area') {
                if(!activeDivId && level.dividers && level.dividers.length > 0) {
                    playSound('error');
                    isWalking = false;
                    return showMsg("לחצו על אחד מהקווים הכתומים המקווקווים כדי לחלק את הצורה!", "red");
                }
                walker.classList.remove('hidden');
                const list = (level.dividers && level.dividers.length > 0) ? level.dividers.find(d=>d.id === activeDivId).rects : level.rects;
                
                for(let i=0; i<list.length; i++) {
                    playSound('step');
                    const r = list[i];
                    walker.style.transition = 'left 0.8s ease-in-out, top 0.8s ease-in-out';
                    walker.style.left = `${px(r.labelX)}px`; walker.style.top = `${py(r.labelY)}px`;
                    
                    if (helpEnabled) {
                        bubble.innerHTML = `מלבן ${i+1}:<br><div class="flex items-center gap-1 justify-center mt-2" dir="ltr"><span class="font-black text-xl">${r.w} × ${r.h} = </span><input type="number" id="walk-area-inp" class="walk-inp-style border-emerald-500 w-16" onkeydown="if(event.key==='Enter') window.checkWalkAreaStep(${r.w*r.h}, ${i})"> <button onclick="window.checkWalkAreaStep(${r.w*r.h}, ${i})" class="walk-btn-style bg-emerald-500 border-emerald-800">V</button></div>`;
                    } else {
                        bubble.innerHTML = `מלבן ${i+1}: <button onclick="if(coins>=5) { addCoins(-5); document.getElementById('walk-area-w').value=${r.w}; document.getElementById('walk-area-h').value=${r.h}; this.style.display='none'; } else { showMsg('אין מספיק מטבעות!', 'red'); playSound('error'); }" class="bg-amber-100 border border-amber-400 rounded-lg px-2 py-1 text-xs hover:bg-amber-200 transition mb-1 font-bold shadow-sm" title="גלה צלעות (-5🪙)">🪄 שרביט (-5)</button><br><div class="flex items-center gap-1 justify-center mt-2" dir="ltr"><input type="number" id="walk-area-w" class="walk-inp-small" placeholder="צ'"> <span class="font-black">×</span> <input type="number" id="walk-area-h" class="walk-inp-small" placeholder="צ'"> <span class="font-black">=</span> <input type="number" id="walk-area-inp" class="walk-inp-small w-14" placeholder="שטח" onkeydown="if(event.key==='Enter') window.checkWalkAreaStepFull(${r.w}, ${r.h}, ${r.w*r.h}, ${i})"> <button onclick="window.checkWalkAreaStepFull(${r.w}, ${r.h}, ${r.w*r.h}, ${i})" class="walk-btn-style bg-emerald-500 border-emerald-800 px-2">V</button></div>`;
                    }
                    
                    setTimeout(() => document.getElementById(helpEnabled ? 'walk-area-inp' : 'walk-area-w')?.focus(), 50);
                    await new Promise(resolve => { walkStepResolver = resolve; });
                }
                
                playSound('success');
                let cx = 0, cy = 0;
                level.points.forEach(p => { cx += p[0]; cy += p[1]; });
                cx /= level.points.length; cy /= level.points.length;
                walker.style.left = `${px(cx)}px`; walker.style.top = `${py(cy)}px`;
                bubble.innerHTML = `מעולה! עכשיו חברו הכל<br>והקלידו את השטח הכולל למטה.`;
                setTimeout(() => { walker.classList.add('hidden'); isWalking = false; }, 3000);
            }
        }

        window.checkWalkStep = (correctSum) => {
            const inp = document.getElementById('walk-inp');
            if(!inp) return;
            if(parseInt(inp.value) === correctSum) {
                playSound('success');
                addCoins(5);
                if(walkStepResolver) { let res = walkStepResolver; walkStepResolver = null; res(); }
            } else {
                playSound('error');
                inp.classList.add('shake-err'); inp.value = '';
                setTimeout(() => inp.classList.remove('shake-err'), 400);
            }
        };

        window.checkWalkAreaStep = (correctArea, rectIndex) => {
            const inp = document.getElementById('walk-area-inp'); if(!inp) return;
            const val = parseInt(inp.value);
            if(val === correctArea) {
                playSound('success'); addCoins(15);
                inp.classList.remove('border-emerald-500'); inp.classList.add('border-green-500', 'bg-green-100', 'text-green-800'); inp.disabled = true;
                const subInput = document.getElementById(`sub-${rectIndex}`); if(subInput) { subInput.value = correctArea; subInput.classList.add('bg-green-100'); }
                const shapeInput = document.getElementById(`shape-area-inp-${rectIndex}`); if(shapeInput) { shapeInput.value = correctArea; shapeInput.classList.add('bg-green-100', 'border-green-500', 'text-green-800'); }
                setTimeout(() => { if(walkStepResolver) { let res = walkStepResolver; walkStepResolver = null; res(); } }, 400);
            } else {
                playSound('error');
                inp.classList.add('shake-err'); inp.value = ''; setTimeout(() => inp.classList.remove('shake-err'), 400);
            }
        };

        window.checkWalkAreaStepFull = (correctW, correctH, correctArea, rectIndex) => {
            const wInp = document.getElementById('walk-area-w'); const hInp = document.getElementById('walk-area-h'); const aInp = document.getElementById('walk-area-inp');
            let wVal = parseInt(wInp.value); let hVal = parseInt(hInp.value); let aVal = parseInt(aInp.value);
            let dimsCorrect = (wVal === correctW && hVal === correctH) || (wVal === correctH && hVal === correctW);
            let areaCorrect = (aVal === correctArea);

            if(dimsCorrect && areaCorrect) {
                playSound('success'); addCoins(15);
                aInp.classList.remove('border-emerald-500'); aInp.classList.add('border-green-500', 'bg-green-100');
                aInp.disabled = true; wInp.disabled = true; hInp.disabled = true;
                const subInput = document.getElementById(`sub-${rectIndex}`);
                if(subInput) {
                    subInput.value = correctArea; subInput.classList.add('bg-green-100');
                    const inputs = subInput.parentElement.querySelectorAll('input');
                    if(inputs.length >= 3) { inputs[0].value = wVal; inputs[1].value = hVal; }
                }
                const shapeInput = document.getElementById(`shape-area-inp-${rectIndex}`); if(shapeInput) { shapeInput.value = correctArea; shapeInput.classList.add('bg-green-100', 'border-green-500', 'text-green-800'); }
                setTimeout(() => { if(walkStepResolver) { let res = walkStepResolver; walkStepResolver = null; res(); } }, 400);
            } else {
                playSound('error');
                if(!dimsCorrect) { wInp.classList.add('shake-err'); hInp.classList.add('shake-err'); wInp.value=''; hInp.value=''; }
                if(!areaCorrect) { aInp.classList.add('shake-err'); aInp.value=''; }
                setTimeout(() => { wInp.classList.remove('shake-err'); hInp.classList.remove('shake-err'); aInp.classList.remove('shake-err'); }, 400);
            }
        };

        // --- New Inline Area Logic ---
        window.closeInlineArea = (i, w, h) => {
            playSound('step');
            const container = document.getElementById(`area-calc-container-${i}`);
            if (!container) return;
            // Restore default view
            container.innerHTML = `
                <button onclick="openInlineArea(${i}, ${w}, ${h})" class="area-start-btn bg-white/95 hover:bg-emerald-50 text-emerald-800 font-bold py-1.5 px-4 rounded-full shadow-md border-2 border-emerald-400 text-sm flex items-center gap-2 transition-transform transform hover:scale-105">
                    <span>🔍</span> שטח מלבן ${i+1}
                </button>
            `;
        };

        window.openInlineArea = (i, w, h, useWand = false) => {
            playSound('step');
            const container = document.getElementById(`area-calc-container-${i}`);
            if (!container) return;
            
            let wVal = useWand ? w : '';
            let hVal = useWand ? h : '';
            let readonlyAttr = useWand ? 'readonly' : '';
            let wandBg = useWand ? 'bg-amber-50 text-amber-900 border-amber-200 cursor-not-allowed' : 'bg-transparent border-emerald-200';

            // Only show wand button if not already used
            let wandBtnHtml = useWand ? '' : `
                <button onclick="if(coins>=5){ addCoins(-5); openInlineArea(${i}, ${w}, ${h}, true); } else { showMsg('אין מספיק מטבעות לקסם!', 'red'); playSound('error'); }" class="bg-amber-100 hover:bg-amber-200 text-amber-800 rounded px-1.5 h-7 font-bold text-xs border border-amber-300 shadow-sm transition active:scale-95 flex items-center gap-1" title="שרביט מילוי צלעות (-5🪙)">
                    🪄(-5)
                </button>
            `;

            container.innerHTML = `
                <div class="flex items-center justify-center gap-1 bg-white/95 backdrop-blur rounded-xl border-2 border-emerald-500 px-2 py-1.5 shadow-xl w-max mx-auto relative mt-2" dir="ltr">
                    <button onclick="closeInlineArea(${i}, ${w}, ${h})" class="absolute -top-3 -left-3 bg-rose-500 text-white rounded-full w-7 h-7 flex items-center justify-center text-sm font-black border-2 border-white shadow-md hover:bg-rose-600 transition z-50">✕</button>
                    
                    ${wandBtnHtml}

                    <input type="number" id="inline-w-${i}" class="w-8 h-7 text-center font-bold text-sm outline-none border-b-2 focus:border-emerald-500 transition-colors ${wandBg}" placeholder="צ'" value="${wVal}" ${readonlyAttr}>
                    <span class="font-black text-slate-400 text-sm">×</span>
                    <input type="number" id="inline-h-${i}" class="w-8 h-7 text-center font-bold text-sm outline-none border-b-2 focus:border-emerald-500 transition-colors ${wandBg}" placeholder="צ'" value="${hVal}" ${readonlyAttr}>
                    <span class="font-black text-slate-400 text-sm">=</span>
                    <input type="number" id="shape-area-inp-${i}" class="w-12 h-7 text-center font-black text-emerald-700 text-sm outline-none bg-emerald-50 rounded border border-emerald-200 focus:bg-white transition-colors" placeholder="שטח" onkeydown="if(event.key==='Enter') checkInlineAreaFull(${i}, ${w}, ${h}, ${w*h})">
                    <button onclick="checkInlineAreaFull(${i}, ${w}, ${h}, ${w*h})" class="bg-emerald-500 text-white rounded w-7 h-7 ml-0.5 font-black text-sm hover:bg-emerald-600 transition-transform active:scale-95 flex items-center justify-center shadow-sm border-b-2 border-emerald-700 active:border-b-0 active:translate-y-px">V</button>
                </div>
            `;
            
            setTimeout(() => {
                const targetInp = useWand ? document.getElementById(`shape-area-inp-${i}`) : document.getElementById(`inline-w-${i}`);
                if(targetInp) targetInp.focus();
            }, 50);
        };

        window.checkInlineAreaFull = (rectIndex, correctW, correctH, correctArea) => {
            const wInp = document.getElementById(`inline-w-${rectIndex}`);
            const hInp = document.getElementById(`inline-h-${rectIndex}`);
            const aInp = document.getElementById(`shape-area-inp-${rectIndex}`);
            
            let wVal = parseInt(wInp.value);
            let hVal = parseInt(hInp.value);
            let aVal = parseInt(aInp.value);
            
            let dimsCorrect = (wVal === correctW && hVal === correctH) || (wVal === correctH && hVal === correctW);
            let areaCorrect = (aVal === correctArea);

            if(dimsCorrect && areaCorrect) {
                playSound('success'); 
                addCoins(15);
                
                const container = document.getElementById(`area-calc-container-${rectIndex}`);
                if(container) {
                    container.innerHTML = `
                        <div class="bg-green-100 border-2 border-green-500 text-green-800 font-black px-4 py-1.5 rounded-full shadow-sm text-sm flex items-center gap-2 cursor-default mx-auto w-max transition-all transform hover:scale-105">
                            <span>שטח: ${correctArea}</span>
                            <span>✅</span>
                        </div>
                    `;
                }

                const subInput = document.getElementById(`sub-${rectIndex}`); 
                if(subInput) { 
                    subInput.value = correctArea; 
                    subInput.classList.add('bg-green-100'); 
                    const inputs = subInput.parentElement.querySelectorAll('input');
                    if(inputs.length >= 3) { inputs[0].value = wVal; inputs[1].value = hVal; }
                }
            } else {
                playSound('error');
                if(!dimsCorrect) { wInp.classList.add('shake-err'); hInp.classList.add('shake-err'); wInp.value=''; hInp.value=''; }
                if(!areaCorrect) { aInp.classList.add('shake-err'); aInp.value=''; }
                setTimeout(() => { wInp.classList.remove('shake-err'); hInp.classList.remove('shake-err'); aInp.classList.remove('shake-err'); }, 400);
            }
        };

        function selectDivider(div) {
            playSound('step');
            document.getElementById('status-msg').classList.add('hidden');
            
            if(activeDivId === div.id && div.id !== 'dummy') return;
            activeDivId = div.id;
            
            document.querySelectorAll('.divider-line').forEach(l => {
                l.classList.remove('divider-active');
            });
            document.querySelectorAll(`.div-${div.id}`).forEach(l => {
                l.classList.add('divider-active');
            });

            const level = getLevel(cur);
            const rectGroup = document.getElementById('area-rects-group');
            if(rectGroup) {
                rectGroup.innerHTML = '';
                if(div.rects) {
                    div.rects.forEach((r, i) => {
                        const rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
                        rect.setAttribute('x', level.offX + r.x*level.grid);
                        rect.setAttribute('y', level.offY + r.y*level.grid);
                        rect.setAttribute('width', (r.w || 0)*level.grid);
                        rect.setAttribute('height', (r.h || 0)*level.grid);
                        rect.setAttribute('fill', r.fill || '#e0f2fe');
                        rect.setAttribute('opacity', '0.8');
                        rectGroup.appendChild(rect);

                        if(r.labelX && r.labelY) {
                            const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
                            text.setAttribute('x', level.offX + r.labelX*level.grid);
                            text.setAttribute('y', level.offY + r.labelY*level.grid - 35);
                            text.setAttribute('text-anchor', 'middle');
                            text.setAttribute('dominant-baseline', 'middle');
                            text.setAttribute('font-weight', '900');
                            text.setAttribute('font-size', '26');
                            text.setAttribute('fill', '#1e3a8a');
                            text.textContent = `מלבן ${i+1}`;
                            rectGroup.appendChild(text);

                            const fo = document.createElementNS("http://www.w3.org/2000/svg", "foreignObject");
                            fo.setAttribute('x', level.offX + r.labelX*level.grid - 160);
                            fo.setAttribute('y', level.offY + r.labelY*level.grid - 30);
                            fo.setAttribute('width', '320');
                            fo.setAttribute('height', '100');
                            fo.innerHTML = `
                                <div id="area-calc-container-${i}" class="flex flex-col items-center justify-center w-full h-full gap-1">
                                    <button onclick="openInlineArea(${i}, ${r.w}, ${r.h})" class="area-start-btn bg-white/95 hover:bg-emerald-50 text-emerald-800 font-bold py-1.5 px-4 rounded-full shadow-md border-2 border-emerald-400 text-sm flex items-center gap-2 transition-transform transform hover:scale-105">
                                        <span>🔍</span> שטח מלבן ${i+1}
                                    </button>
                                </div>
                            `;
                            rectGroup.appendChild(fo);
                        }
                    });
                }
            }
            
            const aInputs = document.getElementById('a-inputs'); aInputs.innerHTML = '';
            document.getElementById('composite-final-area').classList.remove('hidden');
            
            if(div.rects) {
                div.rects.forEach((r, i) => {
                    const row = document.createElement('div'); row.className = 'bg-slate-50 p-3 rounded-xl border-2 border-slate-200 flex items-center justify-between flex-row-reverse shadow-sm panel-3d mb-2';
                    row.innerHTML = `
                        <div class="flex items-center gap-2">
                            <div class="font-black text-slate-500">מלבן ${i+1}</div>
                            <button onclick="if(coins>=5){ addCoins(-5); document.getElementById('w-${i}').value = ${r.w}; document.getElementById('h-${i}').value = ${r.h}; this.classList.add('scale-90', 'opacity-50', 'pointer-events-none'); } else { showMsg('אין מספיק מטבעות! שרביט עולה 5 מטבעות.', 'red'); playSound('error'); }" class="bg-amber-100 border border-amber-300 rounded p-1 text-sm hover:bg-amber-200 transition shadow-sm flex items-center gap-1" title="גלה צלעות עבור מלבן זה (-5🪙)">
                                <svg class="w-4 h-4 text-amber-600"><use href="#icon-wand"></use></svg>(-5<svg class="w-3 h-3 inline"><use href="#icon-coin"></use></svg>)
                            </button>
                        </div>
                        <div class="flex items-center gap-1" dir="ltr">
                            <input type="number" id="w-${i}" class="w-12 p-1.5 border-2 rounded-lg text-center font-bold outline-none focus:border-emerald-400 shadow-inner" value="${helpEnabled?r.w:''}">
                            <span class="text-slate-400 font-bold">×</span>
                            <input type="number" id="h-${i}" class="w-12 p-1.5 border-2 rounded-lg text-center font-bold outline-none focus:border-emerald-400 shadow-inner" value="${helpEnabled?r.h:''}">
                            <span class="text-slate-400 font-bold">=</span>
                            <input type="number" id="sub-${i}" class="w-16 p-1.5 border-2 border-emerald-400 rounded-lg text-center font-black text-emerald-700 outline-none shadow-inner" placeholder="שטח?">
                        </div>`;
                    aInputs.appendChild(row);
                });
            }
        }

        function checkPart(type) {
            const level = getLevel(cur);
            if(type === 'perimeter') {
                const val = parseInt(document.getElementById('p-final').value);
                checkEasterEgg(val, level.ansP);
                if(val === level.ansP) {
                    playSound('success');
                    document.getElementById('p-status-msg').classList.remove('hidden');
                    document.getElementById('status-msg').classList.add('hidden');
                } else {
                    playSound('error');
                    showMsg("חישוב ההיקף לא מדויק, כדאי לנסות לחבר שוב.", "red");
                }
            } else {
                const val = parseInt(document.getElementById('a-final').value);
                checkEasterEgg(val, level.ansA);
                if(val === level.ansA) {
                    playSound('success');
                    document.getElementById('a-status-msg').classList.remove('hidden');
                    document.getElementById('status-msg').classList.add('hidden');
                } else {
                    playSound('error');
                    showMsg("חישוב השטח הכולל לא מדויק.", "red");
                }
            }
        }

        document.getElementById('check-btn').onclick = () => {
            const level = getLevel(cur);
            const pVal = parseInt(document.getElementById('p-final').value);
            const aVal = parseInt(document.getElementById('a-final').value);
            
            let pOk = (pVal === level.ansP);
            let aOk = (level.ansA === null || aVal === level.ansA);

            if(pOk && aOk) {
                playSound('tada');
                addCoins(50);
                document.getElementById('status-msg').classList.add('hidden');
                confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 } });
                document.getElementById('success-modal').classList.remove('hidden');
            } else if (!pOk && !aOk) {
                playSound('error');
                showMsg("יש טעויות גם בחישוב ההיקף וגם בשטח. נסו לבדוק הכל שוב.", "red");
            } else if (!pOk) {
                playSound('error');
                showMsg("חישוב השטח מדויק, אך יש טעות בהיקף הצורה.", "red");
            } else if (!aOk) {
                playSound('error');
                showMsg("היקף הצורה חושב נכון, אך יש טעות בחישוב השטח הכולל.", "red");
            }
        };

        document.getElementById('modal-next-btn').onclick = () => {
            document.getElementById('success-modal').classList.add('hidden');
            cur++; init();
        };

        function showMsg(t, c) {
            const m = document.getElementById('status-msg');
            m.innerHTML = `<span class="mr-2">${c==='red'?'⚠️':'✅'}</span>` + t; 
            m.classList.remove('hidden');
            m.className = `w-full p-4 mt-4 rounded-2xl font-black border-2 text-center flex items-center justify-center panel-3d ${c==='red'?'bg-red-50 text-red-700 border-red-200':'bg-green-50 text-green-700 border-green-200'}`;
        }

        function renderStars() {
            const r = document.getElementById('stars-row'); r.innerHTML = '';
            for(let i=0; i<MAX_LEVELS; i++) {
                const s = document.createElement('span'); s.textContent = '★';
                s.className = i < cur ? 'text-amber-500' : 'text-slate-200';
                r.appendChild(s);
            }
        }
    </script>
</body>
</html>
