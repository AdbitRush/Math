                    const hw = document.createElementNS("http://www.w3.org/2000/svg", "line");
                    hw.setAttribute('x1', level.offX + r.x*level.grid); hw.setAttribute('y1', level.offY + r.y*level.grid);
                    hw.setAttribute('x2', level.offX + (r.x+r.w)*level.grid); hw.setAttribute('y2', level.offY + r.y*level.grid);
                    hw.setAttribute('stroke', '#ef4444'); hw.setAttribute('stroke-width', '8');
                    const hh = document.createElementNS("http://www.w3.org/2000/svg", "line");
                    hh.setAttribute('x1', level.offX + (r.x+r.w)*level.grid); hh.setAttribute('y1', level.offY + r.y*level.grid);
                    hh.setAttribute('x2', level.offX + (r.x+r.w)*level.grid); hh.setAttribute('y2', level.offY + (r.y+r.h)*level.grid);
                    hh.setAttribute('stroke', '#3b82f6'); hh.setAttribute('stroke-width', '8');
                    hlGroup.innerHTML = ''; hlGroup.appendChild(hw); hlGroup.appendChild(hh);

                    walker.style.transition = 'left 0.8s ease-in-out, top 0.8s ease-in-out';
                    walker.style.left = `${px(r.labelX)}px`; walker.style.top = `${py(r.labelY)}px`;
                    
                    if (py(r.labelY) < 120) {
                        bubble.style.bottom = 'auto'; bubble.style.top = '100%'; bubble.style.marginTop = '15px'; bubble.style.marginBottom = '0';
                    } else {
                        bubble.style.bottom = '100%'; bubble.style.top = 'auto'; bubble.style.marginTop = '0'; bubble.style.marginBottom = '15px';
                    }
                    
                    await new Promise(res => setTimeout(res, 800)); 
                    
                    if (helpEnabled) {
                        bubble.innerHTML = `<div class="text-center font-bold text-lg text-emerald-900 mb-1">מלבן ${i+1}:</div><div class="flex items-center gap-2 justify-center" dir="ltr"><span class="font-black text-xl text-emerald-800"><span class="text-red-600">${r.w}</span> × <span class="text-blue-600">${r.h}</span> = </span><input type="number" id="walk-area-inp" class="w-16 h-10 border-2 border-emerald-500 rounded-lg text-center font-bold text-lg outline-none" onkeydown="if(event.key==='Enter') window.checkWalkAreaStepFull(${r.w*r.h}, ${i})"> <button onclick="window.checkWalkAreaStepFull(${r.w*r.h}, ${i})" class="bg-emerald-500 text-white font-bold h-10 px-4 rounded-lg border-b-4 border-emerald-800">V</button></div>`;
                    } else {
                        bubble.innerHTML = `<div class="text-center font-bold text-lg text-emerald-900 mb-1">מלבן ${i+1}:</div><div class="flex items-center gap-2 justify-center" dir="ltr"><span class="font-black text-xl text-emerald-800"><span class="text-red-600">${r.w}</span> × <span class="text-blue-600">${r.h}</span> = </span> <input type="number" id="walk-area-inp" class="w-16 h-10 border-2 border-emerald-500 rounded-lg text-center font-bold text-lg outline-none" placeholder="?" onkeydown="if(event.key==='Enter') window.checkWalkAreaStepFull(${r.w*r.h}, ${i})"> <button onclick="window.checkWalkAreaStepFull(${r.w*r.h}, ${i})" class="bg-emerald-500 text-white font-bold h-10 px-4 rounded-lg border-b-4 border-emerald-800">V</button></div>`;
                    }
                    
                    setTimeout(() => document.getElementById('walk-area-inp')?.focus(), 50);
                    
                    await new Promise(resolve => { walkStepResolver = resolve; });
                    
                    await new Promise(res => setTimeout(res, 1200)); 
                }
                
                playSound('success');
                hlGroup.innerHTML = '';
                let cx = 0, cy = 0;
                level.points.forEach(p => { cx += p[0]; cy += p[1]; });
                cx /= level.points.length; cy /= level.points.length;
                walker.style.left = `${px(cx)}px`; walker.style.top = `${py(cy)}px`;
                bubble.style.bottom = '100%'; bubble.style.top = 'auto'; bubble.style.marginTop = '0'; bubble.style.marginBottom = '15px';
                bubble.innerHTML = `<div class="text-center font-bold text-lg text-emerald-900">מעולה! עכשיו חברו הכל<br>והקלידו את השטח הכולל למטה.</div>`;
                setTimeout(() => { walker.classList.add('hidden'); isWalking = false; }, 3000);
            }
        }

        window.checkWalkStep = (correctSum, oldSum, len) => {
            const inp = document.getElementById('walk-inp');
            if(!inp) return;
            if(parseInt(inp.value) === correctSum) {
                playSound('success');
                addCoins(5);
                gameStats.perimeterWalk.right++;
                
                inp.parentElement.innerHTML = `<span dir="ltr" class="text-xl">${oldSum} + ${len}</span> = <b class="text-green-600 text-3xl mx-2">${correctSum}</b> <span class="text-green-500 text-2xl drop-shadow-sm">✅</span>`;
                
                if(walkStepResolver) { let res = walkStepResolver; walkStepResolver = null; res(); }
            } else {
                playSound('error');
                gameStats.perimeterWalk.wrong++;
                inp.classList.add('shake-err'); inp.value = '';
                setTimeout(() => inp.classList.remove('shake-err'), 400);
            }
        };

        window.checkWalkAreaStepFull = (correctArea, rectIndex) => {
            const aInp = document.getElementById('walk-area-inp');
            if (!aInp) return;
            let aVal = parseInt(aInp.value) || correctArea; 
            let areaCorrect = (aVal === correctArea);

            if(areaCorrect) {
                playSound('success'); addCoins(15);
                gameStats.areaWalk.right++;
                
                aInp.parentElement.innerHTML = `<span class="text-green-600 font-black text-3xl mx-2">${correctArea}</span> <span class="text-green-500 text-2xl drop-shadow-sm">✅</span>`;
                
                const subInput = document.getElementById(`sub-${rectIndex}`);
                if(subInput) {
                    subInput.value = correctArea; subInput.classList.add('bg-green-100');
                }
                const shapeInput = document.getElementById(`shape-area-inp-${rectIndex}`); if(shapeInput) { shapeInput.value = correctArea; shapeInput.classList.add('bg-green-100', 'border-green-500', 'text-green-800'); }
                
                const container = document.getElementById(`area-calc-container-${rectIndex}`);
                if(container) {
                    container.innerHTML = `
                        <div class="bg-green-100 border-2 border-green-500 text-green-800 font-black px-4 py-1.5 rounded-full shadow-sm text-sm flex items-center gap-2 cursor-default transition-all transform hover:scale-105 pointer-events-auto mt-2">
                            <span dir="ltr">שטח: ${correctArea}</span>
                            <span>✅</span>
                        </div>
                    `;
                }

                if(walkStepResolver) { let res = walkStepResolver; walkStepResolver = null; res(); }
            } else {
                playSound('error');
                gameStats.areaWalk.wrong++;
                aInp.classList.add('shake-err'); aInp.value='';
                setTimeout(() => { aInp.classList.remove('shake-err'); }, 400);
            }
        };

        window.useAreaWand = (i, w, h, rx, ry) => {
            if(coins >= 5) {
                addCoins(-5);
                playSound('success');
                openInlineArea(i, w, h, rx, ry, true);
            } else {
                showMsg('אין מספיק מטבעות לקסם שטח! (עולה 5)', 'red');
                playSound('error');
            }
        };

        window.closeInlineArea = (i, w, h, rx, ry) => {
            playSound('step');
            const hlGroup = document.getElementById("walk-highlight-group");
            if(hlGroup) hlGroup.innerHTML = '';

            const container = document.getElementById(`area-calc-container-${i}`);
            if (!container) return;
            container.innerHTML = `
                <button onclick="openInlineArea(${i}, ${w}, ${h}, ${rx}, ${ry})" class="area-start-btn bg-white/95 hover:bg-emerald-50 text-emerald-800 font-bold py-1 px-4 rounded-full shadow-md border-2 border-emerald-400 text-sm flex items-center gap-2 transition-transform transform hover:scale-105 pointer-events-auto mt-2">
                    <span>🔍</span> שטח מלבן ${i+1}
                </button>
            `;
        };

        window.openInlineArea = (i, w, h, rx, ry, useWand = false) => {
            playSound('step');
            
            const level = getLevel(cur);
            const hlGroup = document.getElementById("walk-highlight-group");
            if(hlGroup) {
                hlGroup.innerHTML = '';
                const hw = document.createElementNS("http://www.w3.org/2000/svg", "line");
                hw.setAttribute('x1', level.offX + rx*level.grid); hw.setAttribute('y1', level.offY + ry*level.grid);
                hw.setAttribute('x2', level.offX + (rx+w)*level.grid); hw.setAttribute('y2', level.offY + ry*level.grid);
                hw.setAttribute('stroke', '#ef4444'); hw.setAttribute('stroke-width', '8');
                const hh = document.createElementNS("http://www.w3.org/2000/svg", "line");
                hh.setAttribute('x1', level.offX + (rx+w)*level.grid); hh.setAttribute('y1', level.offY + ry*level.grid);
                hh.setAttribute('x2', level.offX + (rx+w)*level.grid); hh.setAttribute('y2', level.offY + (ry+h)*level.grid);
                hh.setAttribute('stroke', '#3b82f6'); hh.setAttribute('stroke-width', '8');
                hlGroup.appendChild(hw); hlGroup.appendChild(hh);
            }

            const container = document.getElementById(`area-calc-container-${i}`);
            if (!container) return;
            
            let areaVal = useWand ? (w * h) : '';
            let readonlyAttr = useWand ? 'readonly' : '';

            container.innerHTML = `
                <div class="flex items-center justify-center gap-2 bg-white/95 backdrop-blur rounded-xl border-2 border-emerald-500 pl-2 pr-3 py-1.5 shadow-xl w-max relative mt-2 pointer-events-auto">
                    <button onclick="closeInlineArea(${i}, ${w}, ${h}, ${rx}, ${ry})" class="absolute -top-3 -left-3 bg-rose-500 text-white rounded-full w-7 h-7 flex items-center justify-center text-sm font-black border-2 border-white shadow-md hover:bg-rose-600 transition z-50">✕</button>
                    
                    <div class="flex items-center gap-2 font-black" dir="ltr">
                        <span class="text-emerald-900 text-lg"><span class="text-red-600">${w}</span> × <span class="text-blue-600">${h}</span> =</span>
                        <input type="number" id="shape-area-inp-${i}" class="w-16 h-8 text-center text-emerald-700 text-xl outline-none bg-emerald-50 rounded-lg border-2 border-emerald-200 focus:bg-white focus:border-emerald-500 transition-colors" placeholder="?" value="${areaVal}" ${readonlyAttr} onkeydown="if(event.key==='Enter') checkInlineAreaFull(${i}, ${w}, ${h}, ${w*h})">
                    </div>
                    
                    <button onclick="checkInlineAreaFull(${i}, ${w}, ${h}, ${w*h})" class="bg-emerald-500 text-white rounded-lg w-8 h-8 font-black text-sm hover:bg-emerald-600 transition-transform active:scale-95 flex items-center justify-center shadow-sm border-b-4 border-emerald-700 active:border-b-0 active:translate-y-px z-10 relative">V</button>
                </div>
            `;
            
            setTimeout(() => {
                const targetInp = document.getElementById(`shape-area-inp-${i}`);
                if(targetInp && !useWand) targetInp.focus();
                else if (useWand) checkInlineAreaFull(i, w, h, w*h);
            }, 50);
        };

        window.checkInlineAreaFull = (rectIndex, correctW, correctH, correctArea) => {
            const aInp = document.getElementById(`shape-area-inp-${rectIndex}`);
            if (!aInp) return;
            let aVal = parseInt(aInp.value);
            let areaCorrect = (aVal === correctArea);

            if(areaCorrect) {
                playSound('success'); 
                addCoins(15);
                gameStats.areaWalk.right++;
                
                const hlGroup = document.getElementById("walk-highlight-group");
                if(hlGroup) hlGroup.innerHTML = '';

                const container = document.getElementById(`area-calc-container-${rectIndex}`);
                if(container) {
                    container.innerHTML = `
                        <div class="bg-green-100 border-2 border-green-500 text-green-800 font-black px-4 py-1.5 rounded-full shadow-sm text-sm flex items-center gap-2 cursor-default transition-all transform hover:scale-105 pointer-events-auto mt-2">
                            <span dir="ltr">${correctW} × ${correctH} = ${correctArea}</span>
                            <span>✅</span>
                        </div>
                    `;
                }

                const subInput = document.getElementById(`sub-${rectIndex}`); 
                if(subInput) { 
                    subInput.value = correctArea; 
                    subInput.classList.add('bg-green-100'); 
                }
            } else {
                playSound('error');
                gameStats.areaWalk.wrong++;
                aInp.classList.add('shake-err'); aInp.value='';
                setTimeout(() => { aInp.classList.remove('shake-err'); }, 400);
            }
        };

        function selectDivider(div) {
            playSound('step');
            document.getElementById('status-msg').classList.add('hidden');
            
            if(activeDivId === div.id && div.id !== 'dummy') return;
            activeDivId = div.id;
            
            document.querySelectorAll('.divider-line').forEach(l => {
                l.classList.remove('divider-active');
            });
            document.querySelectorAll(`.div-${div.id}`).forEach(l => {
                l.classList.add('divider-active');
            });

            const level = getLevel(cur);
            const world = STORIES[selectedStoryId];
            const rectGroup = document.getElementById('area-rects-group');
            const overlay = document.getElementById('interactive-overlay');
            
            if(rectGroup) {
                rectGroup.innerHTML = '';
                document.querySelectorAll('.area-label-container').forEach(e => e.remove());
                
                if(div.rects) {
                    div.rects.forEach((r, i) => {
                        const rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
                        rect.setAttribute('x', level.offX + r.x*level.grid);
                        rect.setAttribute('y', level.offY + r.y*level.grid);
                        rect.setAttribute('width', (r.w || 0)*level.grid);
                        rect.setAttribute('height', (r.h || 0)*level.grid);
                        rect.setAttribute('fill', r.fill || '#e0f2fe');
                        rect.setAttribute('opacity', '0.6');
                        rectGroup.appendChild(rect);

                        if(r.labelX && r.labelY) {
                            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
                            const adiv = document.createElement('div');
                            adiv.className = 'area-label-container absolute flex flex-col items-center justify-center gap-1';
                            adiv.style.transform = 'translate(-50%, -50%)';
                            adiv.style.zIndex = '30';
                            
                            let svgX = level.offX + r.labelX*level.grid;
                            let svgY = level.offY + r.labelY*level.grid;
                            adiv.style.left = `${svgX * (bbox.width/SVG_W)}px`;
                            adiv.style.top = `${svgY * (bbox.height/SVG_H)}px`;
                            
                            adiv.innerHTML = `
                                <div class="flex items-center justify-center gap-2 text-[#1e3a8a] font-black text-lg bg-white/90 px-3 py-1 rounded-full shadow-md border border-blue-200 pointer-events-auto" dir="rtl">
                                    <span>מלבן ${i+1}</span>
                                    <button onclick="useAreaWand(${i}, ${r.w}, ${r.h}, ${r.x}, ${r.y})" class="bg-amber-100 hover:bg-amber-200 text-amber-700 rounded-full w-8 h-8 flex items-center justify-center border-2 border-amber-300 shadow-sm text-base transition-transform active:scale-90" title="קסם שטח בעזרת ${world.wandName} (5- מטבעות)">${world.wandIcon}</button>
                                </div>
                                <div id="area-calc-container-${i}" class="flex flex-col items-center justify-start w-full">
                                    <button onclick="openInlineArea(${i}, ${r.w}, ${r.h}, ${r.x}, ${r.y})" class="area-start-btn bg-white/95 hover:bg-emerald-50 text-emerald-800 font-bold py-1 px-4 rounded-full shadow-md border-2 border-emerald-400 text-sm flex items-center gap-2 transition-transform transform hover:scale-105 pointer-events-auto mt-2">
                                        <span>🔍</span> שטח מלבן ${i+1}
                                    </button>
                                </div>
                            `;
                            overlay.appendChild(adiv);
                        }
                    });
                }
            }
            
            const aInputs = document.getElementById('a-inputs'); aInputs.innerHTML = '';
            document.getElementById('composite-final-area').classList.remove('hidden');
            
            if(div.rects) {
                div.rects.forEach((r, i) => {
                    const row = document.createElement('div'); row.className = 'bg-slate-50 p-3 rounded-xl border-2 border-slate-200 flex items-center justify-between flex-row-reverse shadow-sm panel-3d mb-2';
                    row.innerHTML = `
                        <div class="flex items-center gap-2">
                            <div class="font-black text-slate-500">מלבן ${i+1}</div>
                        </div>
                        <div class="flex items-center gap-1" dir="rtl">
                            <span class="text-slate-600 font-bold">שטח:</span>
                            <input type="number" id="sub-${i}" class="w-16 p-1.5 border-2 border-emerald-400 rounded-lg text-center font-black text-emerald-700 outline-none shadow-inner" placeholder="?">
                        </div>`;
                    aInputs.appendChild(row);
                });
            }
        }

        function checkPart(type) {
            const level = getLevel(cur);
            if(type === 'perimeter') {
                const val = parseInt(document.getElementById('p-final').value);
                checkEasterEgg(val, level.ansP);
                if(val === level.ansP) {
                    playSound('success');
                    gameStats.perimeterTotal.right++;
                    document.getElementById('p-status-msg').classList.remove('hidden');
                    document.getElementById('status-msg').classList.add('hidden');
                } else {
                    playSound('error');
                    gameStats.perimeterTotal.wrong++;
                    showMsg("חישוב ההיקף לא מדויק, כדאי לנסות לחבר שוב.", "red");
                }
            } else {
                const val = parseInt(document.getElementById('a-final').value);
                checkEasterEgg(val, level.ansA);
                if(val === level.ansA) {
                    playSound('success');
                    gameStats.areaTotal.right++;
                    document.getElementById('a-status-msg').classList.remove('hidden');
                    document.getElementById('status-msg').classList.add('hidden');
                } else {
                    playSound('error');
                    gameStats.areaTotal.wrong++;
                    showMsg("חישוב השטח הכולל לא מדויק.", "red");
                }
            }
        }

        document.getElementById('check-btn').onclick = () => {
            const level = getLevel(cur);
            const pVal = parseInt(document.getElementById('p-final').value);
            const aVal = parseInt(document.getElementById('a-final').value);
            
            let pOk = (pVal === level.ansP);
            let aOk = (level.ansA === null || level.ansA === undefined || aVal === level.ansA);

            if(pOk && aOk) {
                playSound('tada');
                addCoins(50);
                document.getElementById('status-msg').classList.add('hidden');
                confetti({ particleCount: 200, spread: 100, origin: { y: 0.6 }, colors: ['#facc15', '#ef4444', '#3b82f6', '#10b981', '#a855f7'] });
                document.getElementById('success-modal').classList.remove('hidden');
            } else if (!pOk && !aOk) {
                playSound('error');
                showMsg("יש טעויות גם בחישוב ההיקף וגם בשטח. נסו לבדוק הכל שוב.", "red");
            } else if (!pOk) {
                playSound('error');
                showMsg("חישוב השטח מדויק, אך יש טעות בהיקף הצורה.", "red");
            } else if (!aOk) {
                playSound('error');
                showMsg("היקף הצורה חושב נכון, אך יש טעות בחישוב השטח הכולל.", "red");
            }
        };

        document.getElementById('modal-next-btn').onclick = () => {
            document.getElementById('success-modal').classList.add('hidden');
            cur++; init();
        };

        function showMsg(t, c) {
            const m = document.getElementById('status-msg');
            m.innerHTML = `<span class="mr-2">${c==='red'?'⚠️':'✅'}</span>` + t; 
            m.classList.remove('hidden');
            m.className = `w-full p-4 mt-4 rounded-2xl font-black border-2 text-center flex items-center justify-center panel-3d ${c==='red'?'bg-red-50 text-red-700 border-red-200':'bg-green-50 text-green-700 border-green-200'}`;
        }

        function renderStars() {
            const r = document.getElementById('stars-row'); r.innerHTML = '';
            for(let i=0; i<MAX_LEVELS; i++) {
                const s = document.createElement('span'); s.textContent = '★';
                s.className = i < cur ? 'text-amber-500' : 'text-slate-200';
                r.appendChild(s);
            }
        }
    </script>
</body>
</html>
