            const container = document.getElementById('coins-display');
            container.classList.remove('coin-anim');
            void container.offsetWidth;
            container.classList.add('coin-anim');
            
            if (amount > 0) {
                playSound('coin'); container.style.borderColor = '#F59E0B';
            } else if (amount < 0) {
                container.style.borderColor = '#ef4444';
                setTimeout(() => container.style.borderColor = '', 500);
            }
