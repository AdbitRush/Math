                let svgX = level.offX + s.x*level.grid;
                let svgY = level.offY + s.y*level.grid;
                
                let padding = (s.type === 'missing') ? 30 : -25;
                
                if(s.pos === 'top') svgY -= padding;
                if(s.pos === 'bottom') svgY += padding;
                if(s.pos === 'left') svgX -= padding;
                if(s.pos === 'right') svgX += padding;

                div.style.left = `${svgX * (bbox.width/SVG_W)}px`;
                div.style.top = `${svgY * (bbox.height/SVG_H)}px`;
                
