            highlightGroup.setAttribute("id", "walk-highlight-group");
            svg.appendChild(highlightGroup);

            if(level.dividers) {
                level.dividers.forEach(div => {
                    div.lines.forEach(l => {
                        const visLine = document.createElementNS("http://www.w3.org/2000/svg", "line");
                        visLine.setAttribute('x1', level.offX + l.x1*level.grid); 
                        visLine.setAttribute('y1', level.offY + l.y1*level.grid);
                        visLine.setAttribute('x2', level.offX + l.x2*level.grid); 
                        visLine.setAttribute('y2', level.offY + l.y2*level.grid);
                        visLine.setAttribute('class', `divider-line div-${div.id}`);
                        visLine.style.pointerEvents = 'none'; 
                        svg.appendChild(visLine);
                        
                        const hitLine = document.createElementNS("http://www.w3.org/2000/svg", "line");
                        hitLine.setAttribute('x1', level.offX + l.x1*level.grid); 
                        hitLine.setAttribute('y1', level.offY + l.y1*level.grid);
                        hitLine.setAttribute('x2', level.offX + l.x2*level.grid); 
                        hitLine.setAttribute('y2', level.offY + l.y2*level.grid);
                        hitLine.setAttribute('stroke', 'transparent');
                        hitLine.setAttribute('stroke-width', '60');
                        hitLine.style.cursor = 'pointer';
                        
                        hitLine.onmouseenter = () => {
                            if (!visLine.classList.contains('divider-active')) {
                                visLine.style.strokeWidth = '6';
                                visLine.style.opacity = '1';
                            }
                        };
                        hitLine.onmouseleave = () => {
                            if (!visLine.classList.contains('divider-active')) {
                                visLine.style.strokeWidth = '';
                                visLine.style.opacity = '';
                            }
                        };
                        hitLine.onclick = () => selectDivider(div);
