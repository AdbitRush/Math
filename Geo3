                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1, y2:h1}], rects: [{x:0, y:0, w:w1, h:h1, fill: "rgba(186, 230, 253, 0.4)", labelX: w1/2, labelY: h1/2}, {x:0, y:h1, w:w1+w2, h:h2, fill: "rgba(187, 247, 208, 0.4)", labelX: (w1+w2)/2, labelY: h1+h2/2}] }
                ],
                ansP: (w1+w2+h1+h2)*2, ansA: 67
            };
        }

        function genLShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*6); let h1 = 3 + Math.floor(Math.random()*5); 
            let w2 = 3 + Math.floor(Math.random()*6); let h2 = 4 + Math.floor(Math.random()*5); 
            let sides = [
                { x: w1/2, y: 0, val: w1, id: 't1', pos: 'top' },
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'right' },
                { x: w1+w2/2, y: h1, val: w2, id: 't2', pos: 'top' },
                { x: w1+w2, y: h1+h2/2, val: h2, id: 'r', pos: 'right' },
                { x: (w1+w2)/2, y: h1+h2, val: w1+w2, id: 'b', pos: 'bottom' },
                { x: 0, y: (h1+h2)/2, val: h1+h2, id: 'l', pos: 'left' }
            ];
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = w2; sides[2].parts = ['b', 't1']; sides[2].op = '-'; }
            if (diff >= 2) { sides[5].type = 'missing'; sides[5].correct = h1+h2; sides[5].parts = ['r', 'il']; sides[5].op = '+'; }

            return {
                points: [[0,0], [w1,0], [w1,h1], [w1+w2,h1], [w1+w2,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}], rects: [{x:0, y:0, w:w1, h:h1+h2, fill: "rgba(186, 230, 253, 0.4)", labelX: w1/2, labelY: (h1+h2)/2}, {x:w1, y:h1, w:w2, h:h2, fill: "rgba(187, 247, 208, 0.4)", labelX: w1+w2/2, labelY: h1+h2/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1, y2:h1}], rects: [{x:0, y:0, w:w1, h:h1, fill: "rgba(186, 230, 253, 0.4)", labelX: w1/2, labelY: h1/2}, {x:0, y:h1, w:w1+w2, h:h2, fill: "rgba(187, 247, 208, 0.4)", labelX: (w1+w2)/2, labelY: h1+h2/2}] }
                ],
                ansP: (w1+w2+h1+h2)*2, ansA: (w1*(h1+h2)) + (w2*h2)
            };
        }

        function genStairShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*5); let h1 = 3 + Math.floor(Math.random()*4); 
            let w2 = 4 + Math.floor(Math.random()*6); let h2 = 3 + Math.floor(Math.random()*4); 
            let sides = [
                { x: w1/2, y: h1, val: w1, id: 'ib', pos: 'top' }, 
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'left' },
                { x: w1+w2/2, y: 0, val: w2, id: 't', pos: 'top' }, 
                { x: w1+w2, y: (h1+h2)/2, val: h1+h2, id: 'r', pos: 'right' },
                { x: (w1+w2)/2, y: h1+h2, val: w1+w2, id: 'b', pos: 'bottom'}, 
                { x: 0, y: h1+h2/2, val: h2, id: 'l', pos: 'left'}
            ];
            if (diff >= 1) { sides[0].type = 'missing'; sides[0].correct = w1; sides[0].parts = ['b', 't']; sides[0].op='-'; }
            if (diff >= 2) { sides[3].type = 'missing'; sides[3].correct = h1+h2; sides[3].parts = ['l', 'il']; sides[3].op='+'; }

            return {
                points: [[0,h1], [w1,h1], [w1,0], [w1+w2,0], [w1+w2,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}], rects: [{x:0, y:h1, w:w1, h:h2, fill: "rgba(254, 243, 199, 0.4)", labelX: w1/2, labelY: h1+h2/2}, {x:w1, y:0, w:w2, h:h1+h2, fill: "rgba(187, 247, 208, 0.4)", labelX: w1+w2/2, labelY: (h1+h2)/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1+w2, y2:h1}], rects: [{x:0, y:h1, w:w1+w2, h:h2, fill: "rgba(254, 243, 199, 0.4)", labelX: (w1+w2)/2, labelY: h1+h2/2}, {x:w1, y:0, w:w2, h:h1, fill: "rgba(187, 247, 208, 0.4)", labelX: w1+w2/2, labelY: h1/2}] }
                ],
                ansP: (w1+w2+h1+h2)*2, ansA: (w1*h2) + (w2*(h1+h2))
            };
        }

        function genUShape(diff) {
            let w1 = 3 + Math.floor(Math.random()*3), w2 = 3 + Math.floor(Math.random()*4), w3 = 3 + Math.floor(Math.random()*3), h1 = 3 + Math.floor(Math.random()*4), h2 = 2 + Math.floor(Math.random()*3);
            let sides = [
                { x: w1/2, y: 0, val: w1, id: 't1', pos: 'top' }, 
                { x: w1, y: h1/2, val: h1, id: 'il', pos: 'right' },
                { x: w1+w2/2, y: h1, val: w2, id: 'ib', pos: 'top' }, 
                { x: w1+w2, y: h1/2, val: h1, id: 'ir', pos: 'left' },
                { x: w1+w2+w3/2, y: 0, val: w3, id: 't2', pos: 'top' }, 
                { x: w1+w2+w3, y: (h1+h2)/2, val: h1+h2, id: 'r', pos: 'right' },
                { x: (w1+w2+w3)/2, y: h1+h2, val: w1+w2+w3, id: 'b', pos: 'bottom' }, 
                { x: 0, y: (h1+h2)/2, val: h1+h2, id: 'l', pos: 'left' }
            ];
            if (diff >= 1) { sides[2].type = 'missing'; sides[2].correct = w2; sides[2].parts = ['b', 't1', 't2']; sides[2].op=['-', '-']; }
            if (diff >= 2) { sides[7].type = 'missing'; sides[7].correct = h1+h2; sides[7].parts = ['r']; sides[7].op='='; } 

            return {
                points: [[0,0], [w1,0], [w1,h1], [w1+w2,h1], [w1+w2,0], [w1+w2+w3,0], [w1+w2+w3,h1+h2], [0,h1+h2]], sides: sides,
                dividers: [
                    { id: 'd1', lines: [{x1:w1, y1:h1, x2:w1, y2:h1+h2}, {x1:w1+w2, y1:h1, x2:w1+w2, y2:h1+h2}], rects: [{x:0, y:0, w:w1, h:h1+h2, fill: "rgba(186, 230, 253, 0.4)", labelX: w1/2, labelY: (h1+h2)/2}, {x:w1, y:h1, w:w2, h:h2, fill: "rgba(254, 243, 199, 0.4)", labelX: w1+w2/2, labelY: h1+h2/2}, {x:w1+w2, y:0, w:w3, h:h1+h2, fill: "rgba(187, 247, 208, 0.4)", labelX: w1+w2+w3/2, labelY: (h1+h2)/2}] },
                    { id: 'd2', lines: [{x1:0, y1:h1, x2:w1, y2:h1}, {x1:w1+w2, y1:h1, x2:w1+w2+w3, y2:h1}], rects: [{x:0, y:0, w:w1, h:h1, fill: "rgba(186, 230, 253, 0.4)", labelX: w1/2, labelY: h1/2}, {x:0, y:h1, w:w1+w2+w3, h:h2, fill: "rgba(254, 243, 199, 0.4)", labelX: (w1+w2+w3)/2, labelY: h1+h2/2}, {x:w1+w2, y:0, w:w3, h:h1, fill: "rgba(187, 247, 208, 0.4)", labelX: w1+w2+w3/2, labelY: h1/2}] }
                ],
                ansP: (w1+w2+w3+h1+h2)*2 + (h1*2), ansA: (w1*(h1+h2)) + (w2*h2) + (w3*(h1+h2))
            };
        }

        function genSimpleRect() {
            let w = 5 + Math.floor(Math.random()*8); let h = 4 + Math.floor(Math.random()*6);
            return {
                points: [[0,0], [w,0], [w,h], [0,h]],
                sides: [{x:w/2, y:0, val:w, id:'t', pos:'top'}, {x:w, y:h/2, val:h, id:'r', pos:'right'}, {x:w/2, y:h, val:w, id:'b', pos:'bottom'}, {x:0, y:h/2, val:h, id:'l', pos:'left'}],
                dividers: [], rects: [{x:0, y:0, w:w, h:h, fill: "rgba(186, 230, 253, 0.4)", labelX: w/2, labelY: h/2}], ansP: (w+h)*2, ansA: w*h
            };
        }
        
        function genTriangle() {
            let b = 6 + Math.floor(Math.random()*6); let h = 4 + Math.floor(Math.random()*4);
            let hyp = Math.round(Math.sqrt(b*b + h*h));
            return {
                points: [[0,h], [b,h], [0,0]],
                sides: [{x:b/2, y:h, val:b, id:'b', pos:'bottom'}, {x:0, y:h/2, val:h, id:'h', pos:'left'}, {x:b/2, y:h/2, val:hyp, id:'hyp', pos:'top'}],
                dividers: [], rects: [], ansP: b+h+hyp, ansA: Math.round((b*h)/2)
            };
        }

        function genParallelogram() {
            let b = 6 + Math.floor(Math.random()*5); let h = 4 + Math.floor(Math.random()*4); let offset = 2 + Math.floor(Math.random()*3);
            let hyp = Math.round(Math.sqrt(offset*offset + h*h));
            return {
                points: [[offset, 0], [offset+b, 0], [b, h], [0, h]],
                sides: [{x:offset+b/2, y:0, val:b, id:'t', pos:'top'}, {x:offset/2+b, y:h/2, val:hyp, id:'r', pos:'right'}, {x:b/2, y:h, val:b, id:'b', pos:'bottom'}, {x:offset/2, y:h/2, val:hyp, id:'l', pos:'left'}],
                dividers: [], rects: [], ansP: (b+hyp)*2, ansA: b*h
            };
        }

        function genTrapezoid() {
            let t = 4 + Math.floor(Math.random()*4); let h = 4 + Math.floor(Math.random()*4);
            let off1 = 2 + Math.floor(Math.random()*3); let off2 = 2 + Math.floor(Math.random()*3);
            if ((t + off1 + t + off2) % 2 !== 0) off2 += 1;
            let b = off1 + t + off2;
            let hyp1 = Math.round(Math.sqrt(off1*off1 + h*h));
            let hyp2 = Math.round(Math.sqrt(off2*off2 + h*h));
            return {
                points: [[off1, 0], [off1+t, 0], [b, h], [0, h]],
                sides: [{x:off1+t/2, y:0, val:t, id:'t', pos:'top'}, {x:off1+t+off2/2, y:h/2, val:hyp2, id:'r', pos:'right'}, {x:b/2, y:h, val:b, id:'b', pos:'bottom'}, {x:off1/2, y:h/2, val:hyp1, id:'l', pos:'left'}],
                dividers: [], rects: [], ansP: t+b+hyp1+hyp2, ansA: Math.round(((t+b)*h)/2)
            };
        }

        function genRhombus() {
            let d1 = 6 + Math.floor(Math.random()*4)*2; 
            let d2 = 6 + Math.floor(Math.random()*4)*2; 
            let side = Math.round(Math.sqrt((d1/2)*(d1/2) + (d2/2)*(d2/2)));
            return {
                points: [[d1/2, 0], [d1, d2/2], [d1/2, d2], [0, d2/2]],
                sides: [{x:d1*0.75, y:d2*0.25, val:side, id:'t', pos:'top'}, {x:d1*0.75, y:d2*0.75, val:side, id:'r', pos:'right'}, {x:d1*0.25, y:d2*0.75, val:side, id:'b', pos:'bottom'}, {x:d1*0.25, y:d2*0.25, val:side, id:'l', pos:'left'}],
                dividers: [], rects: [], ansP: side*4, ansA: (d1*d2)/2
            };
        }

        // --- Setup Game ---
        document.getElementById('start-game-btn').onclick = () => {
            initAudio();
            const name = document.getElementById('player-name-input').value.trim();
            if(name) playerName = name;
            
            selectedStoryId = document.getElementById('story-select').value;
            MAX_LEVELS = parseInt(document.getElementById('levels-select').value) || 3;
            
            AVAILABLE_GENERATORS = [];
            if(document.getElementById('chk-comp').checked) AVAILABLE_GENERATORS.push(genLShape, genStairShape, genUShape, genArea67Shape); 
            if(document.getElementById('chk-simple').checked) AVAILABLE_GENERATORS.push(genSimpleRect);
            if(document.getElementById('chk-triangles').checked) AVAILABLE_GENERATORS.push(genTriangle);
            if(document.getElementById('chk-quads').checked) AVAILABLE_GENERATORS.push(genParallelogram, genTrapezoid, genRhombus);
            
            if(AVAILABLE_GENERATORS.length === 0) AVAILABLE_GENERATORS.push(genLShape);

            // SHUFFLE the generators so we actually get variety right away, instead of always L shape first!
            AVAILABLE_GENERATORS.sort(() => Math.random() - 0.5);

            const pNameDisp = document.getElementById('player-name-display');
            if (pNameDisp) pNameDisp.textContent = playerName;
            
            document.querySelectorAll('.player-name-text').forEach(e => e.textContent = playerName);
            document.getElementById('welcome-modal').classList.add('hidden');
            document.getElementById('close-welcome-btn').classList.remove('hidden');
            document.getElementById('scratchpad').classList.remove('hidden');
            
            gameStarted = true; cur = 0; levelsCache = []; coins = 0;
            addCoins(0);
            
            // Reset Stats
            gameStats = {
                missing: { right: 0, wrong: 0 },
                perimeterWalk: { right: 0, wrong: 0 },
                perimeterTotal: { right: 0, wrong: 0 },
                areaWalk: { right: 0, wrong: 0 },
                areaTotal: { right: 0, wrong: 0 }
            };

            init();
        };

        function getLevel(index) {
            if(!levelsCache[index]) {
                const gen = AVAILABLE_GENERATORS[index % AVAILABLE_GENERATORS.length];
                let l = gen(difficulty);
                let maxX=0, maxY=0; l.points.forEach(p=>{if(p[0]>maxX) maxX=p[0]; if(p[1]>maxY) maxY=p[1];});
                
                let grid = Math.min((SVG_W - 220)/maxX, (SVG_H - 220)/maxY);
                l.grid = grid; 
                l.offX = (SVG_W - maxX*grid)/2; 
                
                l.offY = (SVG_H - maxY*grid)/2; // PERFECTLY CENTERED!
                levelsCache[index] = l;
            }
            return levelsCache[index];
        }

        function init() {
            if(!gameStarted || cur >= MAX_LEVELS) {
                if(cur >= MAX_LEVELS) {
                    playSound('tada');
                    generateStatsReport();
                    document.getElementById('report-modal').classList.remove('hidden');
                }
                return;
            }
            
            document.querySelectorAll('.add-helper').forEach(e => e.remove());
            document.querySelectorAll('.area-label-container').forEach(e => e.remove());
            
            activeDivId = null;
            isWalking = false;
            walkStepResolver = null;

            const world = STORIES[selectedStoryId];
            const level = getLevel(cur);
            
            const helpTextSpan = document.getElementById('help-text-span');
