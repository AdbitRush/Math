                } else {
                    const valDiv = document.createElement('div');
                    valDiv.id = 'val-' + s.id;
                    valDiv.className = 'val-display relative z-20';
                    valDiv.textContent = s.val;
                    div.appendChild(valDiv);
                }
                overlay.appendChild(div);
            });
            renderStars();
        }

        // --- Help & Cooldown ---
        document.getElementById('toggle-help-btn').onclick = () => {
            const btn = document.getElementById('toggle-help-btn');
            
            if (helpOnCooldown) {
                playSound('step');
                document.getElementById('buyout-modal').classList.remove('hidden');
                return;
            }

            if (!helpEnabled && cur > 0) {
                if (coins < 10) {
                    playSound('error');
                    showMsg("אין לכם מספיק מטבעות להפעלת העזרה! (עולה 10 מטבעות)", "red");
                    return;
                }
                addCoins(-10);
            }

            helpEnabled = !helpEnabled;
            playSound('step');
            btn.classList.toggle('grayscale-0', helpEnabled);
            document.getElementById('help-indicator').classList.toggle('hidden', !helpEnabled);

            if (!helpEnabled) {
                document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            }

            if (cur > 0) {
                if (helpEnabled) {
                    showMsg("💡 העזרה הופעלה ל-15 שניות בלבד! נצלו אותה מהר.", "green");
                    helpTimeoutId = setTimeout(() => {
                        turnOffHelpAndCooldown(btn);
                    }, 15000);
                } else {
                    clearTimeout(helpTimeoutId);
                    turnOffHelpAndCooldown(btn);
                }
            }
        };

        function turnOffHelpAndCooldown(btn) {
            helpEnabled = false;
            btn.classList.remove('grayscale-0');
            document.getElementById('help-indicator').classList.add('hidden');
            document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            
            helpOnCooldown = true;
            cooldownSeconds = 20;
            btn.style.opacity = '0.7';
            
            document.getElementById('help-icon-span').innerHTML = `<span class="text-xl">⏳${cooldownSeconds}</span>`;
            document.getElementById('help-text-span').innerHTML = "דלג (-20)";
            document.getElementById('help-text-span').classList.add('text-amber-600');
            showMsg("העזרה כבויה ונחה. המתינו או לחצו כדי לדלג תמורת מטבעות! ⏳", "red");
            
            cooldownInterval = setInterval(() => {
                cooldownSeconds--;
                if(cooldownSeconds <= 0) {
                    clearInterval(cooldownInterval);
                    finishCooldown(btn);
                } else {
                    document.getElementById('help-icon-span').innerHTML = `<span class="text-xl">⏳${cooldownSeconds}</span>`;
                }
            }, 1000);
        }

        window.buyoutCooldown = () => {
            if(coins >= 20) {
                addCoins(-20);
                playSound('tada');
                document.getElementById('buyout-modal').classList.add('hidden');
                clearInterval(cooldownInterval);
                finishCooldown(document.getElementById('toggle-help-btn'));
            } else {
                playSound('error');
                showMsg("אין לכם מספיק מטבעות לדילוג! נדרשים 20 מטבעות.", "red");
                document.getElementById('buyout-modal').classList.add('hidden');
            }
        };

        function finishCooldown(btn) {
            helpOnCooldown = false;
            btn.style.opacity = '1';
            document.getElementById('help-icon-span').innerHTML = '<svg class="w-6 h-6"><use href="#icon-bulb"></use></svg>';
            document.getElementById('help-text-span').innerHTML = "עזרה (10)";
            document.getElementById('help-text-span').classList.remove('text-amber-600');
            showMsg("העזרה נחה ומוכנה לפעולה! 💡", "green");
            setTimeout(() => document.getElementById('status-msg').classList.add('hidden'), 3000);
        }

        function getParallelParts(side, level) {
            if (side.parts && side.parts.length > 0) return { parts: side.parts, op: side.op || '+' };
            const isHorizontal = (side.pos === 'top' || side.pos === 'bottom');
            let parallels = level.sides.filter(s =>
                s.id !== side.id && !s.type &&
                ((isHorizontal && (s.pos === 'top' || s.pos === 'bottom')) ||
                 (!isHorizontal && (s.pos === 'left' || s.pos === 'right')))
            );

            if (parallels.length >= 2) {
                for(let i=0; i<parallels.length; i++) {
                    for(let j=i+1; j<parallels.length; j++) {
                        if (parallels[i].val + parallels[j].val === side.correct) return { parts: [parallels[i].id, parallels[j].id], op: '+' };
                        if (Math.abs(parallels[i].val - parallels[j].val) === side.correct) {
                            if (parallels[i].val > parallels[j].val) return { parts: [parallels[i].id, parallels[j].id], op: '-' };
                            else return { parts: [parallels[j].id, parallels[i].id], op: '-' };
                        }
                    }
                }
                return { parts: [parallels[0].id, parallels[1].id], op: '+' };
            } else if (parallels.length === 1) {
                return { parts: [parallels[0].id], op: '=' };
            }
            return null; 
        }

        window.openAddHelper = (el, sideObj) => {
            document.querySelectorAll('.add-helper').forEach(e => e.remove());
            document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));

            playSound('step');
            const side = sideObj;
            const level = getLevel(cur);
            const world = STORIES[selectedStoryId]; // Get world for the correct Wand Icon
            
            const detected = getParallelParts(side, level);
            let partsArr = detected ? detected.parts : [];
            let opStr = detected ? detected.op : '+';

            if (!partsArr || partsArr.length === 0) {
                partsArr = ['fallback_1', 'fallback_2']; 
                opStr = '+';
            }

            if(helpEnabled && partsArr.length > 0) {
                partsArr.forEach(pid => {
                    if (pid.startsWith('fallback')) return;
                    const pel = document.getElementById('val-' + pid);
                    if(pel) pel.classList.add('highlight-parallel');
                });
            }

            const cleanupFn = () => {
                document.querySelectorAll('.highlight-parallel').forEach(e => e.classList.remove('highlight-parallel'));
            };

            const helper = document.createElement('div');
            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
            const relY = el.parentElement.offsetTop / bbox.height;
            const relX = el.parentElement.offsetLeft / bbox.width;
            
            let posClass = 'helper-top';
            if(relY < 0.2) posClass = 'helper-bottom';
            else if(relX < 0.2) posClass = 'helper-right';
            else if(relX > 0.8) posClass = 'helper-left';
            
            helper.className = `add-helper flex flex-col gap-2 ${posClass}`;
            helper.dir = 'ltr'; 
            
            let hintRevealed = false;

            const renderEquation = () => {
                helper.innerHTML = ''; 

                const closeX = document.createElement('div'); closeX.className = 'close-x'; closeX.textContent = '✕';
                closeX.onclick = (ev) => { ev.stopPropagation(); cleanupFn(); helper.remove(); };
                helper.appendChild(closeX);

                const eqRow = document.createElement('div');
                eqRow.className = 'flex items-center gap-1';

                partsArr.forEach((pid, i) => {
                    const ps = level.sides.find(x => x.id === pid);
                    let actualVal = ps ? (ps.type === 'missing' ? ps.correct : ps.val) : '?';
                    let isRevealed = helpEnabled || hintRevealed;

                    const box = document.createElement('div');
                    if (isRevealed) {
                        box.className = 'eq-box-small bg-green-100 border-2 border-green-500 text-green-800';
                        box.innerHTML = `<span>${actualVal}</span>`;
                        
                        if(hintRevealed && ps && !ps.type) {
                            const pel = document.getElementById('val-' + pid);
                            if(pel) {
                                pel.classList.add('highlight-parallel');
                                setTimeout(() => pel.classList.remove('highlight-parallel'), 3000);
                            }
                        }
                    } else {
                        box.className = 'eq-box-small bg-slate-50 border-2 border-dashed border-slate-400 text-slate-400';
                        box.innerHTML = `<span>?</span>`;
                    }
                    eqRow.appendChild(box);
                    
                    if(i < partsArr.length - 1) {
                        const opSpan = document.createElement('span'); 
                        opSpan.className = 'font-black text-xl text-slate-500 px-1'; 
                        opSpan.textContent = Array.isArray(opStr) ? opStr[i] : opStr;
                        eqRow.appendChild(opSpan);
                    }
                });

                const eqSpan = document.createElement('span'); 
                eqSpan.className = 'font-black text-xl text-blue-600 px-1'; 
                eqSpan.textContent = '=';
                eqRow.appendChild(eqSpan);

                const total = document.createElement('input'); 
                total.type = 'number'; total.className = 'total-v shadow-sm'; 
                total.placeholder = "?"; 
                eqRow.appendChild(total);

                const vBtn = document.createElement('button');
                vBtn.className = 'bg-blue-600 hover:bg-blue-700 text-white w-10 h-10 rounded-lg font-black text-xl transition btn-3d shadow-md border-blue-800 flex-shrink-0 flex items-center justify-center ml-1';
                vBtn.textContent = 'V';
                vBtn.onclick = () => {
                    if(side.type === 'missing') confirmSide(helper, side, cleanupFn, el.parentElement);
                    else { playSound('step'); cleanupFn(); helper.remove(); }
                };
                total.onkeydown = (e) => { if(e.key === 'Enter') vBtn.click(); };
                eqRow.appendChild(vBtn);

                helper.appendChild(eqRow);

                if (!helpEnabled && !hintRevealed) {
                    const wandRow = document.createElement('div');
                    wandRow.className = 'w-full flex justify-center mt-1 border-t-2 border-dashed border-slate-200 pt-2';
                    const wandBtn = document.createElement('button');
                    wandBtn.className = 'bg-amber-100 hover:bg-amber-200 text-amber-800 border-2 border-amber-300 rounded-lg px-3 py-1 font-black text-xs flex items-center justify-center gap-1 shadow-sm transition active:scale-95';
                    // Use world-specific icon
                    wandBtn.innerHTML = `רמז צלעות בעזרת ${world.wandName} (2- <svg class="w-4 h-4 inline"><use href="#icon-coin"></use></svg>) ${world.wandIcon}`;
                    wandBtn.onclick = () => {
                        if (coins >= 2) {
                            addCoins(-2);
                            playSound('success');
                            hintRevealed = true;
                            renderEquation();
                        } else {
                            showMsg('אין מספיק מטבעות לקסם! חסר לכם כסף.', 'red');
                            playSound('error');
                        }
                    };
                    wandRow.appendChild(wandBtn);
                    helper.appendChild(wandRow);
                }

                setTimeout(() => total.focus(), 50);
            };

            renderEquation();
            el.parentElement.appendChild(helper);
        };

        function confirmSide(helper, side, cleanupFn, container) {
            const totalInp = helper.querySelector('.total-v');
            const val = parseInt(totalInp.value);
            
            if(val === side.correct) {
                playSound('success');
                addCoins(10);
                gameStats.missing.right++;
                
                side.type = null;
                side.val = val;

                const newDiv = document.createElement('div');
                newDiv.id = 'val-' + side.id;
                newDiv.className = 'val-display relative z-20 !bg-green-100 !border-green-500 !text-green-800';
                newDiv.textContent = val;
                
                const level = getLevel(cur);
                const bbox = document.getElementById('canvas-container').getBoundingClientRect();
                let svgX = level.offX + side.x*level.grid;
                let svgY = level.offY + side.y*level.grid;
                let padding = -25; 
                
                if(side.pos === 'top') svgY -= padding;
                if(side.pos === 'bottom') svgY += padding;
                if(side.pos === 'left') svgX -= padding;
                if(side.pos === 'right') svgX += padding;

                container.style.left = `${svgX * (bbox.width/SVG_W)}px`;
                container.style.top = `${svgY * (bbox.height/SVG_H)}px`;
                
                container.innerHTML = '';
                container.appendChild(newDiv);
                
                cleanupFn();
                document.getElementById('status-msg').classList.add('hidden'); 
            } else {
                playSound('error');
                gameStats.missing.wrong++;
                totalInp.classList.add('shake-err'); setTimeout(()=>totalInp.classList.remove('shake-err'), 400);
            }
        }

        async function startWalk(type) {
            if(isWalking) return;
            const level = getLevel(cur);
            if(document.querySelectorAll('.side-input-btn').length > 0) {
                playSound('error');
                return showMsg("גלו קודם את כל הצלעות החסרות עם סימני השאלה!", "red");
            }
            isWalking = true;
            const walker = document.getElementById('knight-walker');
            const bubble = document.getElementById('knight-bubble');
            const bbox = document.getElementById('canvas-container').getBoundingClientRect();
            const px = (x) => (level.offX + x*level.grid)*(bbox.width/SVG_W);
            const py = (y) => (level.offY + y*level.grid)*(bbox.height/SVG_H);
            const hlGroup = document.getElementById("walk-highlight-group");
            hlGroup.innerHTML = '';

            if(type === 'perimeter') {
                walker.classList.remove('hidden');
                let sum = 0;
                const pInputs = document.getElementById('p-inputs');
                pInputs.innerHTML = '<div class="text-slate-400 text-sm font-bold w-full text-right mb-2" dir="rtl">מספרים שנאספו בטיול:</div>';
                
                walker.style.transition = 'none';
                walker.style.left = `${px(level.points[0][0])}px`;
                walker.style.top = `${py(level.points[0][1])}px`;
                
                bubble.style.bottom = '100%'; bubble.style.top = 'auto'; bubble.style.marginTop = '0'; bubble.style.marginBottom = '15px';
                bubble.innerHTML = '<div class="text-center font-bold text-lg text-indigo-900">יוצאים לדרך!<br>מתחילים להקיף את הצורה...</div>';
                await new Promise(r => setTimeout(r, 1500)); 
                
                for(let i=0; i<level.points.length; i++) {
                    const p1 = level.points[i]; 
                    const p2 = level.points[(i+1)%level.points.length];
                    const len = (level.sides[i] && level.sides[i].val) ? level.sides[i].val : Math.round(Math.sqrt(Math.pow(p1[0]-p2[0],2) + Math.pow(p1[1]-p2[1],2)));
                    
                    // Draw red line highlight
                    const lLine = document.createElementNS("http://www.w3.org/2000/svg", "line");
                    lLine.setAttribute('x1', level.offX + p1[0]*level.grid);
                    lLine.setAttribute('y1', level.offY + p1[1]*level.grid);
                    lLine.setAttribute('x2', level.offX + p2[0]*level.grid);
                    lLine.setAttribute('y2', level.offY + p2[1]*level.grid);
                    lLine.setAttribute('stroke', '#ef4444'); 
                    lLine.setAttribute('stroke-width', '8');
                    lLine.setAttribute('stroke-linecap', 'round');
                    hlGroup.appendChild(lLine);

                    const midX = (p1[0] + p2[0]) / 2;
                    const midY = (p1[1] + p2[1]) / 2;
                    
                    playSound('step');
                    walker.style.transition = 'left 0.6s linear, top 0.6s linear';
                    walker.style.left = `${px(midX)}px`; 
                    walker.style.top = `${py(midY)}px`;
                    
                    if (py(midY) < 120) {
                        bubble.style.bottom = 'auto'; bubble.style.top = '100%'; bubble.style.marginTop = '15px'; bubble.style.marginBottom = '0';
                    } else {
                        bubble.style.bottom = '100%'; bubble.style.top = 'auto'; bubble.style.marginTop = '0'; bubble.style.marginBottom = '15px';
                    }
                    
                    await new Promise(r => setTimeout(r, 600));

                    if (i === 0) {
                        bubble.innerHTML = `<div class="text-center font-bold text-lg text-indigo-900">אורך צלע ראשונה:</div><div class="text-center text-4xl text-indigo-700 font-black mt-2">${len}</div>`;
                        sum += len;
                        await new Promise(r => setTimeout(r, 1500));
                    } else {
                        if (helpEnabled) {
                            bubble.innerHTML = `<div class="text-center text-indigo-900 font-bold mb-2 text-xl" dir="ltr">${sum} + ${len} = <b class="text-3xl">${sum+len}</b></div>`;
                            await new Promise(r => setTimeout(r, 1200));
                            sum += len;
                        } else {
                            bubble.innerHTML = `
                                <div class="text-center text-indigo-900 font-bold mb-2 text-xl" dir="ltr">${sum} + ${len} =</div>
                                <div class="flex items-center justify-center gap-2">
                                    <input type="number" id="walk-inp" class="w-16 h-10 border-2 border-indigo-500 rounded-lg text-center font-bold text-lg outline-none focus:border-indigo-700" onkeydown="if(event.key==='Enter') window.checkWalkStep(${sum+len}, ${sum}, ${len})"> 
                                    <button onclick="window.checkWalkStep(${sum+len}, ${sum}, ${len})" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold h-10 px-4 rounded-lg border-b-4 border-indigo-800 active:border-b-0 active:translate-y-1">V</button>
                                </div>`;
                            setTimeout(() => document.getElementById('walk-inp')?.focus(), 50); 
                            
                            await new Promise(resolve => { walkStepResolver = resolve; });
                            sum += len;
                            
                            await new Promise(r => setTimeout(r, 1200)); 
                        }
                    }

                    const box = document.createElement('div'); box.className = 'perimeter-box'; box.textContent = len;
                    pInputs.appendChild(box);
                    if(i < level.points.length - 1) {
                        const plus = document.createElement('span'); plus.className='font-black text-blue-400 text-xl'; plus.textContent='+';
                        pInputs.appendChild(plus);
                    }
                    
                    walker.style.transition = 'left 0.4s linear, top 0.4s linear';
                    walker.style.left = `${px(p2[0])}px`; 
                    walker.style.top = `${py(p2[1])}px`;
                    await new Promise(r => setTimeout(r, 400));
                }
                
                playSound('success');
                let centerX = 0, centerY = 0;
                level.points.forEach(p => { centerX += p[0]; centerY += p[1]; });
                centerX /= level.points.length; centerY /= level.points.length;
                walker.style.left = `${px(centerX)}px`; walker.style.top = `${py(centerY)}px`;
                bubble.style.bottom = '100%'; bubble.style.top = 'auto'; bubble.style.marginTop = '0'; bubble.style.marginBottom = '15px';
                bubble.innerHTML = `<div class="text-center font-bold text-lg text-indigo-900">הגענו לסוף! <br>עכשיו הקלידו את התשובה הסופית למטה.</div>`;
                setTimeout(() => { walker.classList.add('hidden'); isWalking = false; hlGroup.innerHTML = ''; }, 3000);
            
            } else if (type === 'area') {
                if(!activeDivId && level.dividers && level.dividers.length > 0) {
                    playSound('error');
                    isWalking = false;
                    return showMsg("לחצו על אחד מהקווים הכתומים המקווקווים כדי לחלק את הצורה!", "red");
                }
                
                if (level.dividers.length === 0 && level.rects.length === 0) {
                     playSound('error');
                     isWalking = false;
                     return showMsg("הצורה הזו לא זקוקה לחלוקה. פשוט היעזרו בנוסחה המתאימה מדף הנוסחאות!", "green");
                }

                walker.classList.remove('hidden');
                const list = (level.dividers && level.dividers.length > 0) ? level.dividers.find(d=>d.id === activeDivId).rects : level.rects;
                
                for(let i=0; i<list.length; i++) {
                    playSound('step');
                    const r = list[i];
                    
